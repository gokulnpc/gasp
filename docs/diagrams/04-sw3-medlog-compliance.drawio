        <mxCell id="ej" value="yes → next med" style="edgeStyle=orthogonalEdgeStyle;rounded=1;sketch=1;html=1;endArrow=block;endFill=1;strokeWidth=2;dashed=1;dashPattern=4 4;strokeColor=#D6B656;fontSize=9;fontColor=#D6B656;exitX=0;exitY=0.5;entryX=0;entryY=0.6;" edge="1" parent="1" source="d2" target="loop"><mxGeometry relative="1" as="geometry" /></mxCell>
