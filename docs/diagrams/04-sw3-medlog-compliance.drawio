        <mxCell id="ed" style="edgeStyle=orthogonalEdgeStyle;rounded=1;sketch=1;html=1;endArrow=block;endFill=1;strokeWidth=2;strokeColor=#555555;" edge="1" parent="1" source="loop" target="d1"><mxGeometry relative="1" as="geometry" /></mxCell>
