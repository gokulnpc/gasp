<mxfile host="app.diagrams.net" agent="claude" version="24.0.0">
  <diagram id="sw3" name="04 · SW3 Med-Log &amp; Compliance">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="1200" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title" value="SUBWORKFLOW 3 — Caregiver Med-Log &amp; Compliance Check-In" style="text;html=1;align=center;verticalAlign=middle;fontSize=20;fontStyle=1;fontColor=#1A1A1A;" vertex="1" parent="1"><mxGeometry x="200" y="16" width="1000" height="34" as="geometry" /></mxCell>
        <mxCell id="badge" value="3" style="ellipse;whiteSpace=wrap;html=1;sketch=1;fillColor=#FFFFFF;strokeColor=#82B366;strokeWidth=3;fontSize=20;fontStyle=1;fontColor=#82B366;" vertex="1" parent="1"><mxGeometry x="140" y="14" width="44" height="44" as="geometry" /></mxCell>

        <mxCell id="trig" value="&lt;b&gt;TRIGGER&lt;/b&gt;&#10;Caregiver calls in to close out shift&#10;(Orchestrator routes to SW3)" style="rounded=1;whiteSpace=wrap;html=1;sketch=1;arcSize=40;strokeWidth=2;fillColor=#D5E8D4;strokeColor=#82B366;align=center;verticalAlign=middle;fontSize=12;" vertex="1" parent="1"><mxGeometry x="450" y="80" width="320" height="70" as="geometry" /></mxCell>

        <mxCell id="n1" value="Identify shift + patient being closed out" style="rounded=1;whiteSpace=wrap;html=1;sketch=1;arcSize=10;strokeWidth=2;fillColor=#DAE8FC;strokeColor=#6C8EBF;align=center;verticalAlign=middle;fontSize=11;" vertex="1" parent="1"><mxGeometry x="470" y="185" width="280" height="50" as="geometry" /></mxCell>
        <mxCell id="n2" value="Load patient&#39;s &lt;b&gt;active daily med layout&lt;/b&gt;&#10;(Task Checklists)" style="rounded=1;whiteSpace=wrap;html=1;sketch=1;arcSize=10;strokeWidth=2;fillColor=#DAE8FC;strokeColor=#6C8EBF;align=center;verticalAlign=middle;fontSize=11;" vertex="1" parent="1"><mxGeometry x="470" y="260" width="280" height="55" as="geometry" /></mxCell>

        <mxCell id="loop" value="&lt;b&gt;For each med in the layout&lt;/b&gt; — strict questionnaire&#10;confirm drug · dose · time" style="rounded=1;whiteSpace=wrap;html=1;sketch=1;arcSize=10;strokeWidth=2;fillColor=#D5E8D4;strokeColor=#82B366;align=center;verticalAlign=middle;fontSize=11;" vertex="1" parent="1"><mxGeometry x="450" y="345" width="320" height="55" as="geometry" /></mxCell>
        <mxCell id="d1" value="Dose&#10;status?" style="rhombus;whiteSpace=wrap;html=1;sketch=1;strokeWidth=2;fillColor=#FFF2CC;strokeColor=#D6B656;align=center;verticalAlign=middle;fontSize=11;" vertex="1" parent="1"><mxGeometry x="530" y="425" width="160" height="90" as="geometry" /></mxCell>

        <mxCell id="given" value="&lt;b&gt;given&lt;/b&gt;&#10;record time" style="rounded=1;whiteSpace=wrap;html=1;sketch=1;arcSize=10;strokeWidth=2;fillColor=#D5E8D4;strokeColor=#82B366;align=center;verticalAlign=middle;fontSize=10;" vertex="1" parent="1"><mxGeometry x="300" y="430" width="150" height="55" as="geometry" /></mxCell>
        <mxCell id="missed" value="&lt;b&gt;missed / refused&lt;/b&gt;&#10;record status + reason" style="rounded=1;whiteSpace=wrap;html=1;sketch=1;arcSize=10;strokeWidth=2;fillColor=#F8CECC;strokeColor=#B85450;align=center;verticalAlign=middle;fontSize=10;" vertex="1" parent="1"><mxGeometry x="770" y="425" width="180" height="55" as="geometry" /></mxCell>
        <mxCell id="prn" value="&lt;b&gt;PRN / ad-hoc&lt;/b&gt;&#10;flag for review" style="rounded=1;whiteSpace=wrap;html=1;sketch=1;arcSize=10;strokeWidth=2;fillColor=#FFF2CC;strokeColor=#D6B656;align=center;verticalAlign=middle;fontSize=10;" vertex="1" parent="1"><mxGeometry x="770" y="500" width="180" height="55" as="geometry" /></mxCell>

        <mxCell id="d2" value="More meds&#10;in layout?" style="rhombus;whiteSpace=wrap;html=1;sketch=1;strokeWidth=2;fillColor=#FFF2CC;strokeColor=#D6B656;align=center;verticalAlign=middle;fontSize=11;" vertex="1" parent="1"><mxGeometry x="530" y="580" width="160" height="90" as="geometry" /></mxCell>

        <mxCell id="json" value="&lt;b&gt;Translate confirmations → structured JSON&lt;/b&gt;&#10;(read-back verification per med)" style="rounded=1;whiteSpace=wrap;html=1;sketch=1;arcSize=10;strokeWidth=2;fillColor=#E1D5E7;strokeColor=#9673A6;align=center;verticalAlign=middle;fontSize=11;" vertex="1" parent="1"><mxGeometry x="450" y="710" width="320" height="55" as="geometry" /></mxCell>
        <mxCell id="append" value="&lt;b&gt;Append to append-only audit logs&lt;/b&gt;&#10;Return control to Orchestrator + summary" style="rounded=1;whiteSpace=wrap;html=1;sketch=1;arcSize=10;strokeWidth=2;fillColor=#D5E8D4;strokeColor=#82B366;align=center;verticalAlign=middle;fontSize=11;" vertex="1" parent="1"><mxGeometry x="450" y="790" width="320" height="55" as="geometry" /></mxCell>

        <!-- side panels -->
        <mxCell id="jsonex" value="&lt;b&gt;STRUCTURED OUTPUT (illustrative)&lt;/b&gt;&lt;br&gt;&lt;br&gt;{&lt;br&gt;&amp;nbsp;&quot;shift_id&quot;:&quot;shift_20260711_am&quot;,&lt;br&gt;&amp;nbsp;&quot;caregiver_id&quot;:&quot;cg_014&quot;,&lt;br&gt;&amp;nbsp;&quot;patient_id&quot;:&quot;pt_209&quot;,&lt;br&gt;&amp;nbsp;&quot;administered&quot;:[&lt;br&gt;&amp;nbsp;&amp;nbsp;{&quot;medication&quot;:&quot;Metformin&quot;,&lt;br&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;&quot;dose&quot;:&quot;500mg&quot;,&quot;time&quot;:&quot;08:05&quot;,&lt;br&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;&quot;status&quot;:&quot;given&quot;},&lt;br&gt;&amp;nbsp;&amp;nbsp;{&quot;medication&quot;:&quot;Atorvastatin&quot;,&lt;br&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;&quot;status&quot;:&quot;not_given&quot;,&lt;br&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;&quot;reason&quot;:&quot;patient refused&quot;}],&lt;br&gt;&amp;nbsp;&quot;confirmed_by&quot;:&quot;voice&quot;&lt;br&gt;}" style="rounded=1;whiteSpace=wrap;html=1;sketch=1;arcSize=6;strokeWidth=2;fillColor=#F5F5F5;strokeColor=#9673A6;align=left;verticalAlign=top;spacingLeft=12;spacingTop=10;fontSize=9;fontColor=#444444;fontFamily=Courier New;" vertex="1" parent="1"><mxGeometry x="60" y="345" width="330" height="280" as="geometry" /></mxCell>
        <mxCell id="edge" value="&lt;b&gt;EDGE CASES&lt;/b&gt;&lt;br&gt;&lt;br&gt;• Missed/refused → status + reason, not skip&lt;br&gt;• Off-layout med given → PRN, flag review&lt;br&gt;• Unsure of exact time → best-estimate flag&lt;br&gt;• Call drops mid-log → partial preserved, resume&lt;br&gt;• Corrections → new appended entry w/ provenance&lt;br&gt;&lt;br&gt;&lt;b&gt;VALUE:&lt;/b&gt; error-free, audit-ready data · prevents fines" style="rounded=1;whiteSpace=wrap;html=1;sketch=1;arcSize=6;strokeWidth=2;dashed=1;dashPattern=6 4;fillColor=#F5F5F5;strokeColor=#999999;align=left;verticalAlign=top;spacingLeft=12;spacingTop=10;fontSize=10;fontColor=#444444;" vertex="1" parent="1"><mxGeometry x="60" y="650" width="330" height="200" as="geometry" /></mxCell>

