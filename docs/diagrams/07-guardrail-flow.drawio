<mxfile host="app.diagrams.net" agent="claude" version="24.0.0">
  <diagram id="guardrail" name="07 · PHI Guardrail Flow">
    <mxGraphModel dx="1800" dy="1100" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2220" pageHeight="1380" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title" value="PHI GUARDRAIL LAYER — Read (Disclosure) &amp; Write (Ingestion) Gates around the Passive Agent" style="text;html=1;align=center;verticalAlign=middle;fontSize=20;fontStyle=1;fontColor=#1A1A1A;" vertex="1" parent="1"><mxGeometry x="340" y="14" width="1500" height="34" as="geometry" /></mxCell>
        <mxCell id="legend" value="&lt;b&gt;LEGEND&lt;/b&gt;&lt;br&gt;━▶ solid = data flow&lt;br&gt;&lt;font color=&quot;#B85450&quot;&gt;╌▶ red dashed = fail-closed / deny&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#888888&quot;&gt;╌▶ grey dashed = calls a shared service&lt;/font&gt;&lt;br&gt;&lt;br&gt;&lt;b&gt;Principle:&lt;/b&gt; deterministic checks + policy,&lt;br&gt;never &quot;we told the model to behave.&quot;&lt;br&gt;If a check can&#39;t pass → do NOT disclose,&lt;br&gt;do NOT store raw. Always fail closed." style="rounded=1;whiteSpace=wrap;html=1;sketch=1;arcSize=6;strokeWidth=1;dashed=1;dashPattern=6 4;fillColor=#F5F5F5;strokeColor=#999999;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;fontSize=10;fontColor=#333333;" vertex="1" parent="1"><mxGeometry x="1860" y="60" width="330" height="150" as="geometry" /></mxCell>

        <!-- lane containers -->
        <mxCell id="readLane" value="&lt;b&gt;DISCLOSURE GATE — READ PATH&lt;/b&gt;  (runs before the Active Agent speaks)" style="rounded=1;whiteSpace=wrap;html=1;sketch=1;arcSize=2;strokeWidth=2;dashed=1;dashPattern=8 4;fillColor=#F7FAFF;strokeColor=#6C8EBF;align=left;verticalAlign=top;spacingLeft=14;spacingTop=6;fontSize=13;fontColor=#3B5A80;" vertex="1" parent="1"><mxGeometry x="340" y="100" width="1770" height="150" as="geometry" /></mxCell>
        <mxCell id="writeLane" value="&lt;b&gt;INGESTION GATE — WRITE PATH&lt;/b&gt;  (runs before anything is stored)" style="rounded=1;whiteSpace=wrap;html=1;sketch=1;arcSize=2;strokeWidth=2;dashed=1;dashPattern=8 4;fillColor=#FBF8FE;strokeColor=#9673A6;align=left;verticalAlign=top;spacingLeft=14;spacingTop=6;fontSize=13;fontColor=#6A4A8A;" vertex="1" parent="1"><mxGeometry x="340" y="950" width="1420" height="150" as="geometry" /></mxCell>
        <mxCell id="guardBand" value="&lt;b&gt;GUARDRAIL LAYER — Policy Engine + Shared Services&lt;/b&gt;  (fail-closed · deterministic + guard model · every access &amp;amp; write is audited)" style="rounded=1;whiteSpace=wrap;html=1;sketch=1;arcSize=2;strokeWidth=2;dashed=1;dashPattern=8 4;fillColor=none;strokeColor=#666666;align=left;verticalAlign=top;spacingLeft=14;spacingTop=6;fontSize=13;fontColor=#333333;" vertex="1" parent="1"><mxGeometry x="340" y="410" width="1770" height="180" as="geometry" /></mxCell>

        <!-- framing -->
        <mxCell id="caller" value="Caller" style="shape=umlActor;verticalLabelPosition=bottom;verticalAlign=top;html=1;sketch=1;strokeColor=#333333;fillColor=#DAE8FC;fontSize=11;" vertex="1" parent="1"><mxGeometry x="150" y="60" width="50" height="80" as="geometry" /></mxCell>
        <mxCell id="active" value="&lt;b&gt;ACTIVE AGENT&lt;/b&gt;&lt;br&gt;Voice I/O&lt;br&gt;&lt;br&gt;Never touches the DB directly.&lt;br&gt;Only receives pre-cleaned context;&lt;br&gt;its draft is checked before TTS." style="rounded=1;whiteSpace=wrap;html=1;sketch=1;arcSize=8;strokeWidth=2;fillColor=#DAE8FC;strokeColor=#6C8EBF;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;fontSize=10;fontColor=#1A1A1A;" vertex="1" parent="1"><mxGeometry x="120" y="180" width="200" height="130" as="geometry" /></mxCell>
        <mxCell id="passive" value="&lt;b&gt;PASSIVE AGENT&lt;/b&gt;&lt;br&gt;Context Ledger + Data Access&lt;br&gt;&lt;br&gt;The single choke point.&lt;br&gt;All reads &amp;amp; writes run through&lt;br&gt;the Guardrail Layer below.&lt;br&gt;Assembles context for the read&lt;br&gt;path; captures items for the&lt;br&gt;write path." style="rounded=1;whiteSpace=wrap;html=1;sketch=1;arcSize=8;strokeWidth=2;fillColor=#E1D5E7;strokeColor=#9673A6;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;fontSize=10;fontColor=#1A1A1A;" vertex="1" parent="1"><mxGeometry x="120" y="620" width="200" height="230" as="geometry" /></mxCell>

        <!-- READ steps -->
        <mxCell id="R1" value="&lt;b&gt;1&lt;/b&gt; Context request&#10;intent + caller ID" style="rounded=1;whiteSpace=wrap;html=1;sketch=1;arcSize=10;strokeWidth=2;fillColor=#DAE8FC;strokeColor=#6C8EBF;align=center;verticalAlign=middle;fontSize=10;" vertex="1" parent="1"><mxGeometry x="360" y="150" width="150" height="80" as="geometry" /></mxCell>
        <mxCell id="R2" value="&lt;b&gt;2&lt;/b&gt; Authenticate caller&#10;step-up: DOB / PIN / callback" style="rounded=1;whiteSpace=wrap;html=1;sketch=1;arcSize=10;strokeWidth=2;fillColor=#FFE6CC;strokeColor=#D79B00;align=center;verticalAlign=middle;fontSize=10;" vertex="1" parent="1"><mxGeometry x="535" y="150" width="150" height="80" as="geometry" /></mxCell>
        <mxCell id="R3" value="&lt;b&gt;3&lt;/b&gt; Authorize&#10;Neo4j ReBAC edge query&#10;(caregiver ↔ patient?)" style="rounded=1;whiteSpace=wrap;html=1;sketch=1;arcSize=10;strokeWidth=2;fillColor=#D5E8D4;strokeColor=#82B366;align=center;verticalAlign=middle;fontSize=10;" vertex="1" parent="1"><mxGeometry x="710" y="150" width="150" height="80" as="geometry" /></mxCell>
        <mxCell id="R4" value="&lt;b&gt;4&lt;/b&gt; Minimum-necessary&#10;allowed field set for intent&#10;(Policy Engine)" style="rounded=1;whiteSpace=wrap;html=1;sketch=1;arcSize=10;strokeWidth=2;fillColor=#FFF2CC;strokeColor=#D6B656;align=center;verticalAlign=middle;fontSize=10;" vertex="1" parent="1"><mxGeometry x="885" y="150" width="150" height="80" as="geometry" /></mxCell>
        <mxCell id="R5" value="&lt;b&gt;5&lt;/b&gt; Fetch ONLY&#10;allowed fields&#10;(no over-fetch)" style="rounded=1;whiteSpace=wrap;html=1;sketch=1;arcSize=10;strokeWidth=2;fillColor=#DAE8FC;strokeColor=#6C8EBF;align=center;verticalAlign=middle;fontSize=10;" vertex="1" parent="1"><mxGeometry x="1060" y="150" width="150" height="80" as="geometry" /></mxCell>
        <mxCell id="R6" value="&lt;b&gt;6&lt;/b&gt; Sanitize&#10;prompt-injection filter&#10;(records = untrusted data)" style="rounded=1;whiteSpace=wrap;html=1;sketch=1;arcSize=10;strokeWidth=2;fillColor=#F8CECC;strokeColor=#B85450;align=center;verticalAlign=middle;fontSize=10;" vertex="1" parent="1"><mxGeometry x="1235" y="150" width="150" height="80" as="geometry" /></mxCell>
        <mxCell id="R7" value="&lt;b&gt;7&lt;/b&gt; Redact + tokenize&#10;mask what needn&#39;t be&#10;spoken (Presidio)" style="rounded=1;whiteSpace=wrap;html=1;sketch=1;arcSize=10;strokeWidth=2;fillColor=#E1D5E7;strokeColor=#9673A6;align=center;verticalAlign=middle;fontSize=10;" vertex="1" parent="1"><mxGeometry x="1410" y="150" width="150" height="80" as="geometry" /></mxCell>
        <mxCell id="R8" value="&lt;b&gt;8&lt;/b&gt; Grounded context&#10;→ Active Agent drafts&#10;the utterance" style="rounded=1;whiteSpace=wrap;html=1;sketch=1;arcSize=10;strokeWidth=2;fillColor=#DAE8FC;strokeColor=#6C8EBF;align=center;verticalAlign=middle;fontSize=10;" vertex="1" parent="1"><mxGeometry x="1585" y="150" width="150" height="80" as="geometry" /></mxCell>
        <mxCell id="R9" value="&lt;b&gt;9&lt;/b&gt; Output Disclosure Gate&#10;scan utterance vs policy&#10;+ grounding (no leak / no&#10;hallucinated PHI)" style="rounded=1;whiteSpace=wrap;html=1;sketch=1;arcSize=10;strokeWidth=2;fillColor=#F8CECC;strokeColor=#B85450;align=center;verticalAlign=middle;fontSize=10;" vertex="1" parent="1"><mxGeometry x="1760" y="150" width="160" height="80" as="geometry" /></mxCell>
        <mxCell id="R10" value="&lt;b&gt;10&lt;/b&gt; TTS → speak&#10;to the caller" style="rounded=1;whiteSpace=wrap;html=1;sketch=1;arcSize=10;strokeWidth=2;fillColor=#D5E8D4;strokeColor=#82B366;align=center;verticalAlign=middle;fontSize=10;" vertex="1" parent="1"><mxGeometry x="1945" y="150" width="140" height="80" as="geometry" /></mxCell>

        <mxCell id="readfail" value="&lt;b&gt;FAIL-CLOSED (read):&lt;/b&gt;  step-up re-verify  ·  generic reply only  ·  escalate to a human" style="rounded=1;whiteSpace=wrap;html=1;sketch=1;arcSize=10;strokeWidth=2;fillColor=#F8CECC;strokeColor=#B85450;align=center;verticalAlign=middle;fontSize=11;fontColor=#8A2A2A;" vertex="1" parent="1"><mxGeometry x="640" y="300" width="620" height="56" as="geometry" /></mxCell>

        <!-- WRITE steps -->
        <mxCell id="W1" value="&lt;b&gt;1&lt;/b&gt; Captured item&#10;utterance / field" style="rounded=1;whiteSpace=wrap;html=1;sketch=1;arcSize=10;strokeWidth=2;fillColor=#E1D5E7;strokeColor=#9673A6;align=center;verticalAlign=middle;fontSize=10;" vertex="1" parent="1"><mxGeometry x="360" y="1000" width="150" height="80" as="geometry" /></mxCell>
        <mxCell id="W2" value="&lt;b&gt;2&lt;/b&gt; Schema validation&#10;structured JSON only&#10;(reject free-form dumps)" style="rounded=1;whiteSpace=wrap;html=1;sketch=1;arcSize=10;strokeWidth=2;fillColor=#FFF2CC;strokeColor=#D6B656;align=center;verticalAlign=middle;fontSize=10;" vertex="1" parent="1"><mxGeometry x="535" y="1000" width="150" height="80" as="geometry" /></mxCell>
        <mxCell id="W3" value="&lt;b&gt;3&lt;/b&gt; Consent check&#10;recording / storage&#10;consented?" style="rounded=1;whiteSpace=wrap;html=1;sketch=1;arcSize=10;strokeWidth=2;fillColor=#FFE6CC;strokeColor=#D79B00;align=center;verticalAlign=middle;fontSize=10;" vertex="1" parent="1"><mxGeometry x="710" y="1000" width="150" height="80" as="geometry" /></mxCell>
        <mxCell id="W4" value="&lt;b&gt;4&lt;/b&gt; Classify + detect PHI&#10;identifiers &amp;amp; sensitive&#10;categories (Presidio)" style="rounded=1;whiteSpace=wrap;html=1;sketch=1;arcSize=10;strokeWidth=2;fillColor=#F8CECC;strokeColor=#B85450;align=center;verticalAlign=middle;fontSize=10;" vertex="1" parent="1"><mxGeometry x="885" y="1000" width="150" height="80" as="geometry" /></mxCell>
        <mxCell id="W5" value="&lt;b&gt;5&lt;/b&gt; Minimize&#10;drop raw audio /&#10;off-topic chatter" style="rounded=1;whiteSpace=wrap;html=1;sketch=1;arcSize=10;strokeWidth=2;fillColor=#DAE8FC;strokeColor=#6C8EBF;align=center;verticalAlign=middle;fontSize=10;" vertex="1" parent="1"><mxGeometry x="1060" y="1000" width="150" height="80" as="geometry" /></mxCell>
        <mxCell id="W6" value="&lt;b&gt;6&lt;/b&gt; De-identify + tokenize&#10;raw IDs → PHI Vault,&#10;tokens → operational store" style="rounded=1;whiteSpace=wrap;html=1;sketch=1;arcSize=10;strokeWidth=2;fillColor=#E1D5E7;strokeColor=#9673A6;align=center;verticalAlign=middle;fontSize=10;" vertex="1" parent="1"><mxGeometry x="1235" y="1000" width="150" height="80" as="geometry" /></mxCell>
        <mxCell id="W7" value="&lt;b&gt;7&lt;/b&gt; Field-level encryption&#10;sensitive fields (KMS)" style="rounded=1;whiteSpace=wrap;html=1;sketch=1;arcSize=10;strokeWidth=2;fillColor=#D5E8D4;strokeColor=#82B366;align=center;verticalAlign=middle;fontSize=10;" vertex="1" parent="1"><mxGeometry x="1410" y="1000" width="150" height="80" as="geometry" /></mxCell>
        <mxCell id="W8" value="&lt;b&gt;8&lt;/b&gt; Route to store&#10;+ retention TTL&#10;(operational / audit / vault)" style="rounded=1;whiteSpace=wrap;html=1;sketch=1;arcSize=10;strokeWidth=2;fillColor=#DAE8FC;strokeColor=#6C8EBF;align=center;verticalAlign=middle;fontSize=10;" vertex="1" parent="1"><mxGeometry x="1585" y="1000" width="150" height="80" as="geometry" /></mxCell>

        <mxCell id="writefail" value="&lt;b&gt;FAIL-CLOSED (write):&lt;/b&gt;  quarantine → human review  ·  never persist raw / unclassified data" style="rounded=1;whiteSpace=wrap;html=1;sketch=1;arcSize=10;strokeWidth=2;fillColor=#F8CECC;strokeColor=#B85450;align=center;verticalAlign=middle;fontSize=11;fontColor=#8A2A2A;" vertex="1" parent="1"><mxGeometry x="620" y="880" width="620" height="52" as="geometry" /></mxCell>

        <!-- shared services -->
        <mxCell id="policy" value="&lt;b&gt;POLICY ENGINE&lt;/b&gt;&lt;br&gt;rules as data (agency-editable):&lt;br&gt;allowed fields per intent ·&lt;br&gt;disclosure limits · consent ·&lt;br&gt;retention" style="rounded=1;whiteSpace=wrap;html=1;sketch=1;arcSize=8;strokeWidth=2;fillColor=#FFE6CC;strokeColor=#D79B00;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;fontSize=9;fontColor=#1A1A1A;" vertex="1" parent="1"><mxGeometry x="360" y="450" width="195" height="120" as="geometry" /></mxCell>
        <mxCell id="rebac" value="&lt;b&gt;Neo4j ReBAC&lt;/b&gt;&lt;br&gt;relationship auth —&lt;br&gt;is caregiver assigned&lt;br&gt;to this patient?&lt;br&gt;(one-hop edge query)" style="shape=cylinder3;whiteSpace=wrap;html=1;sketch=1;boundedLbl=1;backgroundOutline=1;size=12;strokeWidth=2;fillColor=#D5E8D4;strokeColor=#82B366;align=left;verticalAlign=top;spacingLeft=8;spacingTop=20;fontSize=9;fontColor=#1A1A1A;" vertex="1" parent="1"><mxGeometry x="570" y="450" width="175" height="120" as="geometry" /></mxCell>
        <mxCell id="presidio" value="&lt;b&gt;Presidio&lt;/b&gt;&lt;br&gt;PHI detection +&lt;br&gt;redaction / tokenization&lt;br&gt;(self-hosted, open source)" style="rounded=1;whiteSpace=wrap;html=1;sketch=1;arcSize=8;strokeWidth=2;fillColor=#E1D5E7;strokeColor=#9673A6;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;fontSize=9;fontColor=#1A1A1A;" vertex="1" parent="1"><mxGeometry x="760" y="450" width="175" height="120" as="geometry" /></mxCell>
        <mxCell id="guard" value="&lt;b&gt;Guard Model&lt;/b&gt;&lt;br&gt;Claude Haiku classifier —&lt;br&gt;injection + safety,&lt;br&gt;returns allow / block&lt;br&gt;(structured output)" style="rounded=1;whiteSpace=wrap;html=1;sketch=1;arcSize=8;strokeWidth=2;fillColor=#F8CECC;strokeColor=#B85450;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;fontSize=9;fontColor=#1A1A1A;" vertex="1" parent="1"><mxGeometry x="950" y="450" width="175" height="120" as="geometry" /></mxCell>
        <mxCell id="consent" value="&lt;b&gt;Consent Store&lt;/b&gt;&lt;br&gt;recording / storage&lt;br&gt;consent state per&lt;br&gt;caller &amp;amp; call" style="rounded=1;whiteSpace=wrap;html=1;sketch=1;arcSize=8;strokeWidth=2;fillColor=#FFF2CC;strokeColor=#D6B656;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;fontSize=9;fontColor=#1A1A1A;" vertex="1" parent="1"><mxGeometry x="1140" y="450" width="150" height="120" as="geometry" /></mxCell>
        <mxCell id="vault" value="&lt;b&gt;Tokenization Vault + KMS&lt;/b&gt;&lt;br&gt;token ↔ raw-identifier map ·&lt;br&gt;encryption keys ·&lt;br&gt;tighter access than main DB" style="shape=cylinder3;whiteSpace=wrap;html=1;sketch=1;boundedLbl=1;backgroundOutline=1;size=12;strokeWidth=2;fillColor=#E1D5E7;strokeColor=#9673A6;align=left;verticalAlign=top;spacingLeft=8;spacingTop=20;fontSize=9;fontColor=#1A1A1A;" vertex="1" parent="1"><mxGeometry x="1305" y="450" width="195" height="120" as="geometry" /></mxCell>
        <mxCell id="audit" value="&lt;b&gt;Audit Log&lt;/b&gt; (append-only)&lt;br&gt;every access + write:&lt;br&gt;who · what fields · why ·&lt;br&gt;when (redacted)" style="shape=cylinder3;whiteSpace=wrap;html=1;sketch=1;boundedLbl=1;backgroundOutline=1;size=12;strokeWidth=2;fillColor=#D5E8D4;strokeColor=#82B366;align=left;verticalAlign=top;spacingLeft=8;spacingTop=20;fontSize=9;fontColor=#1A1A1A;" vertex="1" parent="1"><mxGeometry x="1515" y="450" width="180" height="120" as="geometry" /></mxCell>
        <mxCell id="humanreview" value="&lt;b&gt;Human Review Queue&lt;/b&gt;&lt;br&gt;quarantined / failed items&lt;br&gt;surfaced in the staff portal" style="rounded=1;whiteSpace=wrap;html=1;sketch=1;arcSize=8;strokeWidth=2;fillColor=#F8CECC;strokeColor=#B85450;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;fontSize=9;fontColor=#1A1A1A;" vertex="1" parent="1"><mxGeometry x="1715" y="450" width="185" height="120" as="geometry" /></mxCell>

        <!-- stores -->
        <mxCell id="opstore" value="&lt;b&gt;Operational Store&lt;/b&gt; (tokens only)&lt;br&gt;&lt;br&gt;Neo4j roster · Shift Calendars · Task Checklists&lt;br&gt;— direct identifiers replaced by tokens" style="shape=cylinder3;whiteSpace=wrap;html=1;sketch=1;boundedLbl=1;backgroundOutline=1;size=12;strokeWidth=2;fillColor=#DAE8FC;strokeColor=#6C8EBF;align=left;verticalAlign=top;spacingLeft=10;spacingTop=22;fontSize=10;fontColor=#1A1A1A;" vertex="1" parent="1"><mxGeometry x="760" y="630" width="330" height="120" as="geometry" /></mxCell>
        <mxCell id="phivault" value="&lt;b&gt;PHI VAULT (restricted)&lt;/b&gt;&lt;br&gt;&lt;br&gt;raw identifiers · encrypted at rest&lt;br&gt;least-privilege access · separate from ops" style="shape=cylinder3;whiteSpace=wrap;html=1;sketch=1;boundedLbl=1;backgroundOutline=1;size=12;strokeWidth=2;fillColor=#E1D5E7;strokeColor=#9673A6;align=left;verticalAlign=top;spacingLeft=10;spacingTop=22;fontSize=10;fontColor=#1A1A1A;" vertex="1" parent="1"><mxGeometry x="1130" y="630" width="300" height="120" as="geometry" /></mxCell>

        <!-- production hardening band -->
        <mxCell id="prodBand" value="&lt;b&gt;PRODUCTION HARDENING&lt;/b&gt; (beyond the hackathon build)" style="rounded=1;whiteSpace=wrap;html=1;sketch=1;arcSize=2;strokeWidth=2;dashed=1;dashPattern=8 4;fillColor=none;strokeColor=#666666;align=left;verticalAlign=top;spacingLeft=14;spacingTop=6;fontSize=12;fontColor=#333333;" vertex="1" parent="1"><mxGeometry x="340" y="1140" width="1770" height="200" as="geometry" /></mxCell>
        <mxCell id="P1" value="&lt;b&gt;KMS envelope encryption&lt;/b&gt;&#10;everywhere, key rotation" style="rounded=1;whiteSpace=wrap;html=1;sketch=1;arcSize=10;strokeWidth=1;fillColor=#D5E8D4;strokeColor=#82B366;align=center;verticalAlign=middle;fontSize=9;" vertex="1" parent="1"><mxGeometry x="360" y="1185" width="275" height="80" as="geometry" /></mxCell>
        <mxCell id="P2" value="&lt;b&gt;External policy engine&lt;/b&gt;&#10;OPA (Rego) / AWS Cedar" style="rounded=1;whiteSpace=wrap;html=1;sketch=1;arcSize=10;strokeWidth=1;fillColor=#FFE6CC;strokeColor=#D79B00;align=center;verticalAlign=middle;fontSize=9;" vertex="1" parent="1"><mxGeometry x="650" y="1185" width="275" height="80" as="geometry" /></mxCell>
        <mxCell id="P3" value="&lt;b&gt;Managed medical NLP&lt;/b&gt;&#10;AWS Comprehend Medical /&#10;Google Cloud DLP" style="rounded=1;whiteSpace=wrap;html=1;sketch=1;arcSize=10;strokeWidth=1;fillColor=#E1D5E7;strokeColor=#9673A6;align=center;verticalAlign=middle;fontSize=9;" vertex="1" parent="1"><mxGeometry x="940" y="1185" width="275" height="80" as="geometry" /></mxCell>
        <mxCell id="P4" value="&lt;b&gt;42 CFR Part 2&lt;/b&gt;&#10;special-category handling&#10;(mental health / substance)" style="rounded=1;whiteSpace=wrap;html=1;sketch=1;arcSize=10;strokeWidth=1;fillColor=#F8CECC;strokeColor=#B85450;align=center;verticalAlign=middle;fontSize=9;" vertex="1" parent="1"><mxGeometry x="1230" y="1185" width="275" height="80" as="geometry" /></mxCell>
        <mxCell id="P5" value="&lt;b&gt;Retention automation&lt;/b&gt;&#10;TTL purge · right-to-delete" style="rounded=1;whiteSpace=wrap;html=1;sketch=1;arcSize=10;strokeWidth=1;fillColor=#FFF2CC;strokeColor=#D6B656;align=center;verticalAlign=middle;fontSize=9;" vertex="1" parent="1"><mxGeometry x="1520" y="1185" width="275" height="80" as="geometry" /></mxCell>
        <mxCell id="P6" value="&lt;b&gt;ZDR LLM config&lt;/b&gt;&#10;+ DLP monitoring / alerting" style="rounded=1;whiteSpace=wrap;html=1;sketch=1;arcSize=10;strokeWidth=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;align=center;verticalAlign=middle;fontSize=9;" vertex="1" parent="1"><mxGeometry x="1810" y="1185" width="275" height="80" as="geometry" /></mxCell>

        <!-- READ sequential edges -->
        <mxCell id="er12" style="edgeStyle=orthogonalEdgeStyle;rounded=1;sketch=1;html=1;endArrow=block;endFill=1;strokeWidth=2;strokeColor=#555555;" edge="1" parent="1" source="R1" target="R2"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="er23" value="ok" style="edgeStyle=orthogonalEdgeStyle;rounded=1;sketch=1;html=1;endArrow=block;endFill=1;strokeWidth=2;strokeColor=#82B366;fontSize=9;fontColor=#82B366;" edge="1" parent="1" source="R2" target="R3"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="er34" value="ok" style="edgeStyle=orthogonalEdgeStyle;rounded=1;sketch=1;html=1;endArrow=block;endFill=1;strokeWidth=2;strokeColor=#82B366;fontSize=9;fontColor=#82B366;" edge="1" parent="1" source="R3" target="R4"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="er45" style="edgeStyle=orthogonalEdgeStyle;rounded=1;sketch=1;html=1;endArrow=block;endFill=1;strokeWidth=2;strokeColor=#555555;" edge="1" parent="1" source="R4" target="R5"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="er56" style="edgeStyle=orthogonalEdgeStyle;rounded=1;sketch=1;html=1;endArrow=block;endFill=1;strokeWidth=2;strokeColor=#555555;" edge="1" parent="1" source="R5" target="R6"><mxGeometry relative="1" as="geometry" /></mxCell>
