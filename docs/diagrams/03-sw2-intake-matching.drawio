<mxfile host="app.diagrams.net" agent="claude" version="24.0.0">
  <diagram id="sw2" name="03 · SW2 Intake &amp; Graph Matching">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="1200" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title" value="SUBWORKFLOW 2 — Intelligent Intake &amp; Graph-Relational Matching" style="text;html=1;align=center;verticalAlign=middle;fontSize=20;fontStyle=1;fontColor=#1A1A1A;" vertex="1" parent="1"><mxGeometry x="200" y="16" width="1000" height="34" as="geometry" /></mxCell>
        <mxCell id="badge" value="2" style="ellipse;whiteSpace=wrap;html=1;sketch=1;fillColor=#FFFFFF;strokeColor=#D6B656;strokeWidth=3;fontSize=20;fontStyle=1;fontColor=#D6B656;" vertex="1" parent="1"><mxGeometry x="140" y="14" width="44" height="44" as="geometry" /></mxCell>

        <mxCell id="trig" value="&lt;b&gt;TRIGGER&lt;/b&gt;&#10;New patient / referring family starts intake&#10;(Orchestrator routes to SW2)" style="rounded=1;whiteSpace=wrap;html=1;sketch=1;arcSize=40;strokeWidth=2;fillColor=#FFF2CC;strokeColor=#D6B656;align=center;verticalAlign=middle;fontSize=12;" vertex="1" parent="1"><mxGeometry x="450" y="80" width="320" height="70" as="geometry" /></mxCell>

        <mxCell id="d0" value="Existing profile&#10;(caller-ID match)?" style="rhombus;whiteSpace=wrap;html=1;sketch=1;strokeWidth=2;fillColor=#FFF2CC;strokeColor=#D6B656;align=center;verticalAlign=middle;fontSize=10;" vertex="1" parent="1"><mxGeometry x="510" y="185" width="200" height="90" as="geometry" /></mxCell>
        <mxCell id="upd0" value="Update existing profile&#10;(don&#39;t duplicate)" style="rounded=1;whiteSpace=wrap;html=1;sketch=1;arcSize=10;strokeWidth=2;fillColor=#DAE8FC;strokeColor=#6C8EBF;align=center;verticalAlign=middle;fontSize=10;" vertex="1" parent="1"><mxGeometry x="770" y="200" width="180" height="60" as="geometry" /></mxCell>

        <mxCell id="n1" value="&lt;b&gt;Structured profile capture&lt;/b&gt;&#10;care needs · required certs · language ·&#10;location · schedule constraints" style="rounded=1;whiteSpace=wrap;html=1;sketch=1;arcSize=10;strokeWidth=2;fillColor=#FFF2CC;strokeColor=#D6B656;align=center;verticalAlign=middle;fontSize=11;" vertex="1" parent="1"><mxGeometry x="450" y="310" width="320" height="70" as="geometry" /></mxCell>
        <mxCell id="d1" value="Care needs&#10;ambiguous?" style="rhombus;whiteSpace=wrap;html=1;sketch=1;strokeWidth=2;fillColor=#FFF2CC;strokeColor=#D6B656;align=center;verticalAlign=middle;fontSize=10;" vertex="1" parent="1"><mxGeometry x="510" y="410" width="200" height="90" as="geometry" /></mxCell>
        <mxCell id="clar" value="Ask clarifying&#10;questions" style="rounded=1;whiteSpace=wrap;html=1;sketch=1;arcSize=10;strokeWidth=2;fillColor=#FFF2CC;strokeColor=#D6B656;align=center;verticalAlign=middle;fontSize=10;" vertex="1" parent="1"><mxGeometry x="770" y="425" width="160" height="60" as="geometry" /></mxCell>

        <mxCell id="n2" value="&lt;b&gt;Neo4j Cypher match&lt;/b&gt; — map requirements&#10;to roster (language · certifications · proximity)" style="rounded=1;whiteSpace=wrap;html=1;sketch=1;arcSize=10;strokeWidth=2;fillColor=#E1D5E7;strokeColor=#9673A6;align=center;verticalAlign=middle;fontSize=11;" vertex="1" parent="1"><mxGeometry x="450" y="535" width="320" height="60" as="geometry" /></mxCell>
        <mxCell id="n3" value="Rank candidate caregivers&#10;(hard filters + weighted score)" style="rounded=1;whiteSpace=wrap;html=1;sketch=1;arcSize=10;strokeWidth=2;fillColor=#FFF2CC;strokeColor=#D6B656;align=center;verticalAlign=middle;fontSize=11;" vertex="1" parent="1"><mxGeometry x="450" y="625" width="320" height="55" as="geometry" /></mxCell>
        <mxCell id="d2" value="Exact match&#10;found?" style="rhombus;whiteSpace=wrap;html=1;sketch=1;strokeWidth=2;fillColor=#FFF2CC;strokeColor=#D6B656;align=center;verticalAlign=middle;fontSize=11;" vertex="1" parent="1"><mxGeometry x="510" y="710" width="200" height="90" as="geometry" /></mxCell>
        <mxCell id="relax" value="Relax non-critical constraints&#10;(proximity) · re-rank ·&#10;or propose split schedule" style="rounded=1;whiteSpace=wrap;html=1;sketch=1;arcSize=10;strokeWidth=2;fillColor=#F8CECC;strokeColor=#B85450;align=center;verticalAlign=middle;fontSize=10;" vertex="1" parent="1"><mxGeometry x="770" y="720" width="220" height="70" as="geometry" /></mxCell>

        <mxCell id="n4" value="Propose optimal schedule → caller confirms inline" style="rounded=1;whiteSpace=wrap;html=1;sketch=1;arcSize=10;strokeWidth=2;fillColor=#D5E8D4;strokeColor=#82B366;align=center;verticalAlign=middle;fontSize=11;" vertex="1" parent="1"><mxGeometry x="450" y="835" width="320" height="50" as="geometry" /></mxCell>
        <mxCell id="n5" value="&lt;b&gt;Write schedule to calendar&lt;/b&gt; · write audit&#10;Return control to Orchestrator + summary" style="rounded=1;whiteSpace=wrap;html=1;sketch=1;arcSize=10;strokeWidth=2;fillColor=#D5E8D4;strokeColor=#82B366;align=center;verticalAlign=middle;fontSize=11;" vertex="1" parent="1"><mxGeometry x="450" y="910" width="320" height="55" as="geometry" /></mxCell>

        <!-- side panels -->
        <mxCell id="data" value="&lt;b&gt;DATA TOUCHED&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;b&gt;Read:&lt;/b&gt; caregiver roster, certifications, languages, proximity/location nodes, availability&lt;br&gt;&lt;br&gt;&lt;b&gt;Write:&lt;/b&gt; new patient profile, care requirements, proposed / confirmed schedule, audit entry" style="rounded=1;whiteSpace=wrap;html=1;sketch=1;arcSize=6;strokeWidth=2;fillColor=#E1D5E7;strokeColor=#9673A6;align=left;verticalAlign=top;spacingLeft=12;spacingTop=10;fontSize=10;fontColor=#1A1A1A;" vertex="1" parent="1"><mxGeometry x="60" y="310" width="330" height="150" as="geometry" /></mxCell>
        <mxCell id="cypher" value="&lt;b&gt;ILLUSTRATIVE CYPHER&lt;/b&gt;&lt;br&gt;&lt;br&gt;MATCH (p:Patient)-[:REQUIRES]-&amp;gt;(c:Certification),&lt;br&gt;&amp;nbsp;(p)-[:PREFERS]-&amp;gt;(l:Language),&lt;br&gt;&amp;nbsp;(p)-[:LOCATED_AT]-&amp;gt;(loc:Location)&lt;br&gt;MATCH (cg:Caregiver{status:&#39;available&#39;})&lt;br&gt;&amp;nbsp;-[:HOLDS]-&amp;gt;(c),(cg)-[:SPEAKS]-&amp;gt;(l),&lt;br&gt;&amp;nbsp;(cg)-[:BASED_AT]-&amp;gt;()-[n:NEAR]-&amp;gt;(loc)&lt;br&gt;RETURN cg ORDER BY n.minutes ASC" style="rounded=1;whiteSpace=wrap;html=1;sketch=1;arcSize=6;strokeWidth=2;fillColor=#F5F5F5;strokeColor=#9673A6;align=left;verticalAlign=top;spacingLeft=12;spacingTop=10;fontSize=9;fontColor=#444444;fontFamily=Courier New;" vertex="1" parent="1"><mxGeometry x="60" y="485" width="330" height="200" as="geometry" /></mxCell>
        <mxCell id="edge" value="&lt;b&gt;EDGE CASES&lt;/b&gt;&lt;br&gt;&lt;br&gt;• No exact match → relax + re-rank&lt;br&gt;• Partial availability → split schedule&lt;br&gt;• Ambiguous needs → clarify, don&#39;t guess&lt;br&gt;• Duplicate patient → update, not create&lt;br&gt;&lt;br&gt;&lt;b&gt;VALUE:&lt;/b&gt; eliminates manual cross-referencing · faster time-to-first-staffing" style="rounded=1;whiteSpace=wrap;html=1;sketch=1;arcSize=6;strokeWidth=2;dashed=1;dashPattern=6 4;fillColor=#F5F5F5;strokeColor=#999999;align=left;verticalAlign=top;spacingLeft=12;spacingTop=10;fontSize=10;fontColor=#444444;" vertex="1" parent="1"><mxGeometry x="60" y="710" width="330" height="180" as="geometry" /></mxCell>

        <!-- edges -->
        <mxCell id="ea" style="edgeStyle=orthogonalEdgeStyle;rounded=1;sketch=1;html=1;endArrow=block;endFill=1;strokeWidth=2;strokeColor=#555555;" edge="1" parent="1" source="trig" target="d0"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="eb" value="yes" style="edgeStyle=orthogonalEdgeStyle;rounded=1;sketch=1;html=1;endArrow=block;endFill=1;strokeWidth=2;strokeColor=#6C8EBF;fontSize=10;fontColor=#6C8EBF;" edge="1" parent="1" source="d0" target="upd0"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ec" value="no" style="edgeStyle=orthogonalEdgeStyle;rounded=1;sketch=1;html=1;endArrow=block;endFill=1;strokeWidth=2;strokeColor=#555555;fontSize=10;" edge="1" parent="1" source="d0" target="n1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ec2" style="edgeStyle=orthogonalEdgeStyle;rounded=1;sketch=1;html=1;endArrow=block;endFill=1;strokeWidth=2;strokeColor=#6C8EBF;exitX=0.5;exitY=1;entryX=1;entryY=0.3;" edge="1" parent="1" source="upd0" target="n1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ed" style="edgeStyle=orthogonalEdgeStyle;rounded=1;sketch=1;html=1;endArrow=block;endFill=1;strokeWidth=2;strokeColor=#555555;" edge="1" parent="1" source="n1" target="d1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ee" value="yes" style="edgeStyle=orthogonalEdgeStyle;rounded=1;sketch=1;html=1;endArrow=block;endFill=1;strokeWidth=2;strokeColor=#D6B656;fontSize=10;fontColor=#D6B656;" edge="1" parent="1" source="d1" target="clar"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ee2" value="loop" style="edgeStyle=orthogonalEdgeStyle;rounded=1;sketch=1;html=1;endArrow=block;endFill=1;strokeWidth=1;dashed=1;dashPattern=4 4;strokeColor=#D6B656;fontSize=9;fontColor=#D6B656;exitX=0.5;exitY=0;entryX=1;entryY=0.5;" edge="1" parent="1" source="clar" target="n1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ef" value="no" style="edgeStyle=orthogonalEdgeStyle;rounded=1;sketch=1;html=1;endArrow=block;endFill=1;strokeWidth=2;strokeColor=#82B366;fontSize=10;fontColor=#82B366;" edge="1" parent="1" source="d1" target="n2"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="eg" style="edgeStyle=orthogonalEdgeStyle;rounded=1;sketch=1;html=1;endArrow=block;endFill=1;strokeWidth=2;strokeColor=#555555;" edge="1" parent="1" source="n2" target="n3"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="eh" style="edgeStyle=orthogonalEdgeStyle;rounded=1;sketch=1;html=1;endArrow=block;endFill=1;strokeWidth=2;strokeColor=#555555;" edge="1" parent="1" source="n3" target="d2"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ei" value="yes" style="edgeStyle=orthogonalEdgeStyle;rounded=1;sketch=1;html=1;endArrow=block;endFill=1;strokeWidth=2;strokeColor=#82B366;fontSize=10;fontColor=#82B366;" edge="1" parent="1" source="d2" target="n4"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ej" value="no" style="edgeStyle=orthogonalEdgeStyle;rounded=1;sketch=1;html=1;endArrow=block;endFill=1;strokeWidth=2;strokeColor=#B85450;fontSize=10;fontColor=#B85450;" edge="1" parent="1" source="d2" target="relax"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ek" value="re-rank" style="edgeStyle=orthogonalEdgeStyle;rounded=1;sketch=1;html=1;endArrow=block;endFill=1;strokeWidth=1;dashed=1;dashPattern=4 4;strokeColor=#B85450;fontSize=9;fontColor=#B85450;exitX=0.5;exitY=1;entryX=1;entryY=0.5;" edge="1" parent="1" source="relax" target="n4"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="elast" style="edgeStyle=orthogonalEdgeStyle;rounded=1;sketch=1;html=1;endArrow=block;endFill=1;strokeWidth=2;strokeColor=#82B366;" edge="1" parent="1" source="n4" target="n5"><mxGeometry relative="1" as="geometry" /></mxCell>
