        <mxCell id="etc" value="joins conference" style="edgeStyle=orthogonalEdgeStyle;rounded=1;sketch=1;html=1;endArrow=block;endFill=1;startArrow=block;startFill=1;strokeWidth=2;strokeColor=#B85450;fontSize=9;fontColor=#B85450;" edge="1" parent="1" source="n3" target="triage"><mxGeometry relative="1" as="geometry" /></mxCell>
