<mxfile host="app.diagrams.net" agent="claude" version="24.0.0">
  <diagram id="sw4" name="05 · SW4 Interpreter &amp; Escalation">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="1150" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title" value="SUBWORKFLOW 4 — Interpreter &amp; Escalation Bridge (Always-On Guardrail)" style="text;html=1;align=center;verticalAlign=middle;fontSize=20;fontStyle=1;fontColor=#1A1A1A;" vertex="1" parent="1"><mxGeometry x="180" y="16" width="1050" height="34" as="geometry" /></mxCell>
        <mxCell id="badge" value="4" style="ellipse;whiteSpace=wrap;html=1;sketch=1;fillColor=#FFFFFF;strokeColor=#B85450;strokeWidth=3;fontSize=20;fontStyle=1;fontColor=#B85450;" vertex="1" parent="1"><mxGeometry x="120" y="14" width="44" height="44" as="geometry" /></mxCell>

        <mxCell id="trig" value="&lt;b&gt;TRIGGER (during ANY SubWorkflow)&lt;/b&gt;&#10;distress keywords · severe pain · explicit request for a human" style="rounded=1;whiteSpace=wrap;html=1;sketch=1;arcSize=40;strokeWidth=2;dashed=1;dashPattern=8 4;fillColor=#F8CECC;strokeColor=#B85450;align=center;verticalAlign=middle;fontSize=12;" vertex="1" parent="1"><mxGeometry x="430" y="80" width="380" height="70" as="geometry" /></mxCell>

        <mxCell id="d0" value="False positive?&#10;(benign context)" style="rhombus;whiteSpace=wrap;html=1;sketch=1;strokeWidth=2;fillColor=#FFF2CC;strokeColor=#D6B656;align=center;verticalAlign=middle;fontSize=10;" vertex="1" parent="1"><mxGeometry x="500" y="185" width="200" height="90" as="geometry" /></mxCell>
        <mxCell id="ret" value="Offer to return to&#10;prior SubWorkflow" style="rounded=1;whiteSpace=wrap;html=1;sketch=1;arcSize=10;strokeWidth=2;fillColor=#FFF2CC;strokeColor=#D6B656;align=center;verticalAlign=middle;fontSize=10;" vertex="1" parent="1"><mxGeometry x="760" y="200" width="180" height="60" as="geometry" /></mxCell>

        <mxCell id="n1" value="&lt;b&gt;OVERRIDE active session&lt;/b&gt;&#10;pause / close in-progress flow · &lt;b&gt;preserve state&lt;/b&gt; via Passive Agent" style="rounded=1;whiteSpace=wrap;html=1;sketch=1;arcSize=10;strokeWidth=2;fillColor=#F8CECC;strokeColor=#B85450;align=center;verticalAlign=middle;fontSize=11;" vertex="1" parent="1"><mxGeometry x="440" y="310" width="360" height="60" as="geometry" /></mxCell>
        <mxCell id="n2" value="&lt;b&gt;Hot-dial triage coordinator&lt;/b&gt; (Twilio)" style="rounded=1;whiteSpace=wrap;html=1;sketch=1;arcSize=10;strokeWidth=2;fillColor=#DAE8FC;strokeColor=#6C8EBF;align=center;verticalAlign=middle;fontSize=11;" vertex="1" parent="1"><mxGeometry x="480" y="400" width="280" height="50" as="geometry" /></mxCell>
        <mxCell id="d1" value="Coordinator&#10;reachable?" style="rhombus;whiteSpace=wrap;html=1;sketch=1;strokeWidth=2;fillColor=#FFF2CC;strokeColor=#D6B656;align=center;verticalAlign=middle;fontSize=11;" vertex="1" parent="1"><mxGeometry x="520" y="480" width="200" height="90" as="geometry" /></mxCell>
        <mxCell id="fb" value="Fall back to&#10;secondary / on-call" style="rounded=1;whiteSpace=wrap;html=1;sketch=1;arcSize=10;strokeWidth=2;fillColor=#F8CECC;strokeColor=#B85450;align=center;verticalAlign=middle;fontSize=10;" vertex="1" parent="1"><mxGeometry x="770" y="495" width="180" height="60" as="geometry" /></mxCell>

        <mxCell id="n3" value="&lt;b&gt;Patch the lines&lt;/b&gt; — Twilio conference&#10;(caller + coordinator + agent)" style="rounded=1;whiteSpace=wrap;html=1;sketch=1;arcSize=10;strokeWidth=2;fillColor=#DAE8FC;strokeColor=#6C8EBF;align=center;verticalAlign=middle;fontSize=11;" vertex="1" parent="1"><mxGeometry x="440" y="605" width="360" height="55" as="geometry" /></mxCell>
        <mxCell id="n4" value="&lt;b&gt;Main Agent → real-time two-way interpreter&lt;/b&gt;&#10;(STT ↔ translate ↔ TTS, both directions)" style="rounded=1;whiteSpace=wrap;html=1;sketch=1;arcSize=10;strokeWidth=2;fillColor=#E1D5E7;strokeColor=#9673A6;align=center;verticalAlign=middle;fontSize=11;" vertex="1" parent="1"><mxGeometry x="440" y="685" width="360" height="55" as="geometry" /></mxCell>
        <mxCell id="d2" value="Crisis&#10;resolved?" style="rhombus;whiteSpace=wrap;html=1;sketch=1;strokeWidth=2;fillColor=#FFF2CC;strokeColor=#D6B656;align=center;verticalAlign=middle;fontSize=11;" vertex="1" parent="1"><mxGeometry x="520" y="770" width="200" height="90" as="geometry" /></mxCell>

        <mxCell id="n5" value="Log escalation + transcript summary&#10;→ audit logs &amp;amp; staff portal" style="rounded=1;whiteSpace=wrap;html=1;sketch=1;arcSize=10;strokeWidth=2;fillColor=#D5E8D4;strokeColor=#82B366;align=center;verticalAlign=middle;fontSize=11;" vertex="1" parent="1"><mxGeometry x="440" y="890" width="360" height="55" as="geometry" /></mxCell>
        <mxCell id="n6" value="&lt;b&gt;Restore preserved state&lt;/b&gt; · hand back to Orchestrator&#10;(resume prior flow, or end call)" style="rounded=1;whiteSpace=wrap;html=1;sketch=1;arcSize=10;strokeWidth=2;fillColor=#D5E8D4;strokeColor=#82B366;align=center;verticalAlign=middle;fontSize=11;" vertex="1" parent="1"><mxGeometry x="440" y="970" width="360" height="55" as="geometry" /></mxCell>

        <!-- actors -->
        <mxCell id="triage" value="Human Triage&#10;Coordinator" style="shape=umlActor;verticalLabelPosition=bottom;verticalAlign=top;html=1;sketch=1;strokeColor=#333333;fillColor=#F8CECC;fontSize=11;" vertex="1" parent="1"><mxGeometry x="890" y="605" width="50" height="80" as="geometry" /></mxCell>

        <!-- side panels -->
        <mxCell id="data" value="&lt;b&gt;DATA TOUCHED&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;b&gt;Read:&lt;/b&gt; caller profile &amp;amp; language, triage coordinator contact, prior SubWorkflow state&lt;br&gt;&lt;br&gt;&lt;b&gt;Write:&lt;/b&gt; escalation event + transcript summary (audit logs), post-call summary (portal)" style="rounded=1;whiteSpace=wrap;html=1;sketch=1;arcSize=6;strokeWidth=2;fillColor=#E1D5E7;strokeColor=#9673A6;align=left;verticalAlign=top;spacingLeft=12;spacingTop=10;fontSize=10;fontColor=#1A1A1A;" vertex="1" parent="1"><mxGeometry x="60" y="310" width="330" height="150" as="geometry" /></mxCell>
        <mxCell id="integ" value="&lt;b&gt;INTEGRATIONS&lt;/b&gt;&lt;br&gt;&lt;br&gt;• Twilio Voice — conference / patch legs&lt;br&gt;• ElevenLabs — interpreter voice out&lt;br&gt;• STT + translation — two-way interpretation&lt;br&gt;• Passive Agent — state preserve / restore" style="rounded=1;whiteSpace=wrap;html=1;sketch=1;arcSize=6;strokeWidth=2;fillColor=#DAE8FC;strokeColor=#6C8EBF;align=left;verticalAlign=top;spacingLeft=12;spacingTop=10;fontSize=10;fontColor=#1A1A1A;" vertex="1" parent="1"><mxGeometry x="60" y="485" width="330" height="130" as="geometry" /></mxCell>
        <mxCell id="edge" value="&lt;b&gt;EDGE CASES&lt;/b&gt;&lt;br&gt;&lt;br&gt;• Coordinator unreachable → secondary / on-call&lt;br&gt;• False-positive trigger → offer to return&lt;br&gt;• Language unsupported → connect human anyway&lt;br&gt;• Must resume prior flow → restore snapshot&lt;br&gt;&lt;br&gt;&lt;b&gt;PRIORITY:&lt;/b&gt; overrides any active session&lt;br&gt;&lt;b&gt;VALUE:&lt;/b&gt; displaces $0.80–$5.00+/min medical translation" style="rounded=1;whiteSpace=wrap;html=1;sketch=1;arcSize=6;strokeWidth=2;dashed=1;dashPattern=6 4;fillColor=#F5F5F5;strokeColor=#999999;align=left;verticalAlign=top;spacingLeft=12;spacingTop=10;fontSize=10;fontColor=#444444;" vertex="1" parent="1"><mxGeometry x="60" y="640" width="330" height="210" as="geometry" /></mxCell>

        <!-- edges -->
        <mxCell id="ea" style="edgeStyle=orthogonalEdgeStyle;rounded=1;sketch=1;html=1;endArrow=block;endFill=1;strokeWidth=2;strokeColor=#B85450;dashed=1;dashPattern=6 4;" edge="1" parent="1" source="trig" target="d0"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="eb" value="yes" style="edgeStyle=orthogonalEdgeStyle;rounded=1;sketch=1;html=1;endArrow=block;endFill=1;strokeWidth=2;strokeColor=#D6B656;fontSize=10;fontColor=#D6B656;" edge="1" parent="1" source="d0" target="ret"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ec" value="no" style="edgeStyle=orthogonalEdgeStyle;rounded=1;sketch=1;html=1;endArrow=block;endFill=1;strokeWidth=2;strokeColor=#B85450;fontSize=10;fontColor=#B85450;" edge="1" parent="1" source="d0" target="n1"><mxGeometry relative="1" as="geometry" /></mxCell>
