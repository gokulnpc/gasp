        <mxCell id="ee" style="edgeStyle=orthogonalEdgeStyle;rounded=1;sketch=1;html=1;endArrow=block;endFill=1;strokeWidth=2;strokeColor=#555555;" edge="1" parent="1" source="n2" target="d1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ef" value="no" style="edgeStyle=orthogonalEdgeStyle;rounded=1;sketch=1;html=1;endArrow=block;endFill=1;strokeWidth=2;strokeColor=#B85450;fontSize=10;fontColor=#B85450;" edge="1" parent="1" source="d1" target="fb"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="efb" value="retry" style="edgeStyle=orthogonalEdgeStyle;rounded=1;sketch=1;html=1;endArrow=block;endFill=1;strokeWidth=1;dashed=1;dashPattern=4 4;strokeColor=#B85450;fontSize=9;fontColor=#B85450;exitX=0.5;exitY=1;entryX=1;entryY=0.5;" edge="1" parent="1" source="fb" target="n3"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="eg" value="yes" style="edgeStyle=orthogonalEdgeStyle;rounded=1;sketch=1;html=1;endArrow=block;endFill=1;strokeWidth=2;strokeColor=#82B366;fontSize=10;fontColor=#82B366;" edge="1" parent="1" source="d1" target="n3"><mxGeometry relative="1" as="geometry" /></mxCell>
