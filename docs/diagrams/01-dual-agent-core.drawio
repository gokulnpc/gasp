<mxfile host="app.diagrams.net" agent="claude" version="24.0.0">
  <diagram id="dual-agent" name="01 · Dual-Agent Core &amp; Barge-In">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1500" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title" value="DUAL-AGENT CORE — Barge-In Failsafe &amp; Session State" style="text;html=1;align=center;verticalAlign=middle;fontSize=20;fontStyle=1;fontColor=#1A1A1A;" vertex="1" parent="1"><mxGeometry x="280" y="16" width="900" height="34" as="geometry" /></mxCell>

        <!-- Caller/Twilio lane -->
        <mxCell id="caller" value="Caller" style="shape=umlActor;verticalLabelPosition=bottom;verticalAlign=top;html=1;sketch=1;strokeColor=#333333;fillColor=#DAE8FC;fontSize=11;" vertex="1" parent="1"><mxGeometry x="80" y="120" width="50" height="80" as="geometry" /></mxCell>
        <mxCell id="twilio" value="&lt;b&gt;TWILIO MEDIA STREAMS&lt;/b&gt;&lt;br&gt;&lt;br&gt;• Bidirectional audio (μ-law) over WebSocket&lt;br&gt;• Sends inbound audio frames&lt;br&gt;• Plays back TTS audio to caller&lt;br&gt;• &lt;b&gt;Halts playback on interruption&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;sketch=1;arcSize=8;strokeWidth=2;fillColor=#DAE8FC;strokeColor=#6C8EBF;align=left;verticalAlign=top;spacingLeft=12;spacingTop=8;fontSize=11;fontColor=#1A1A1A;" vertex="1" parent="1"><mxGeometry x="240" y="100" width="360" height="120" as="geometry" /></mxCell>

        <!-- Active Agent -->
        <mxCell id="active" value="&lt;b style=&quot;font-size:14px&quot;&gt;ACTIVE AGENT&lt;/b&gt; · Voice I/O&lt;br&gt;&lt;br&gt;• Owns the real-time audio loop&lt;br&gt;• Streaming STT (caller speech → text)&lt;br&gt;• Streaming TTS via ElevenLabs (text → speech)&lt;br&gt;• Lightweight, fast context window&lt;br&gt;• On barge-in: &lt;b&gt;drops in-flight generation&lt;/b&gt;&lt;br&gt;• Pulls latest snapshot from Passive Agent&lt;br&gt;• Adapts to the new intent seamlessly" style="rounded=1;whiteSpace=wrap;html=1;sketch=1;arcSize=8;strokeWidth=2;fillColor=#DAE8FC;strokeColor=#6C8EBF;align=left;verticalAlign=top;spacingLeft=12;spacingTop=10;fontSize=12;fontColor=#1A1A1A;" vertex="1" parent="1"><mxGeometry x="120" y="320" width="380" height="220" as="geometry" /></mxCell>

        <!-- Passive Agent -->
        <mxCell id="passive" value="&lt;b style=&quot;font-size:14px&quot;&gt;PASSIVE AGENT&lt;/b&gt; · Context Ledger&lt;br&gt;&lt;br&gt;• Listens to WebSocket tokens in the background&lt;br&gt;• Maintains the global conversation state&lt;br&gt;• Writes to the central DB &lt;b&gt;off the critical path&lt;/b&gt;&lt;br&gt;• Emits immutable &lt;b&gt;state snapshots&lt;/b&gt; on demand&lt;br&gt;• Tracks active SubWorkflow + prior inputs&lt;br&gt;• Generates the structured post-call summary" style="rounded=1;whiteSpace=wrap;html=1;sketch=1;arcSize=8;strokeWidth=2;fillColor=#E1D5E7;strokeColor=#9673A6;align=left;verticalAlign=top;spacingLeft=12;spacingTop=10;fontSize=12;fontColor=#1A1A1A;" vertex="1" parent="1"><mxGeometry x="700" y="320" width="380" height="220" as="geometry" /></mxCell>

        <!-- Services -->
        <mxCell id="el" value="&lt;b&gt;ElevenLabs&lt;/b&gt;&lt;br&gt;Streaming TTS" style="rounded=1;whiteSpace=wrap;html=1;sketch=1;arcSize=12;strokeWidth=2;fillColor=#FFF2CC;strokeColor=#D6B656;align=center;verticalAlign=middle;fontSize=11;" vertex="1" parent="1"><mxGeometry x="130" y="600" width="160" height="70" as="geometry" /></mxCell>
        <mxCell id="stt" value="&lt;b&gt;STT / ASR&lt;/b&gt;&lt;br&gt;Deepgram (TBD)" style="rounded=1;whiteSpace=wrap;html=1;sketch=1;arcSize=12;strokeWidth=2;fillColor=#D5E8D4;strokeColor=#82B366;align=center;verticalAlign=middle;fontSize=11;" vertex="1" parent="1"><mxGeometry x="330" y="600" width="160" height="70" as="geometry" /></mxCell>
        <mxCell id="claude" value="&lt;b&gt;Claude Opus 4.8&lt;/b&gt;&lt;br&gt;Reasoning + tools" style="rounded=1;whiteSpace=wrap;html=1;sketch=1;arcSize=12;strokeWidth=2;fillColor=#E1D5E7;strokeColor=#9673A6;align=center;verticalAlign=middle;fontSize=11;" vertex="1" parent="1"><mxGeometry x="720" y="600" width="170" height="70" as="geometry" /></mxCell>
        <mxCell id="statedb" value="&lt;b&gt;State Store&lt;/b&gt;&lt;br&gt;fast cache + DB&lt;br&gt;(snapshots)" style="shape=cylinder3;whiteSpace=wrap;html=1;sketch=1;boundedLbl=1;backgroundOutline=1;size=12;strokeWidth=2;fillColor=#E1D5E7;strokeColor=#9673A6;align=center;verticalAlign=middle;fontSize=10;" vertex="1" parent="1"><mxGeometry x="930" y="590" width="150" height="100" as="geometry" /></mxCell>

        <!-- Barge-in sequence -->
        <mxCell id="seqTitle" value="&lt;b&gt;BARGE-IN SEQUENCE&lt;/b&gt; (caller interrupts mid-sentence)" style="text;html=1;align=left;verticalAlign=middle;fontSize=13;fontStyle=1;fontColor=#B85450;" vertex="1" parent="1"><mxGeometry x="120" y="740" width="600" height="24" as="geometry" /></mxCell>
        <mxCell id="s1" value="1. Caller speaks over playback" style="rounded=1;whiteSpace=wrap;html=1;sketch=1;arcSize=40;strokeWidth=2;fillColor=#F8CECC;strokeColor=#B85450;align=center;verticalAlign=middle;fontSize=10;" vertex="1" parent="1"><mxGeometry x="120" y="780" width="180" height="60" as="geometry" /></mxCell>
        <mxCell id="s2" value="2. Twilio halts audio playback" style="rounded=1;whiteSpace=wrap;html=1;sketch=1;arcSize=40;strokeWidth=2;fillColor=#DAE8FC;strokeColor=#6C8EBF;align=center;verticalAlign=middle;fontSize=10;" vertex="1" parent="1"><mxGeometry x="330" y="780" width="180" height="60" as="geometry" /></mxCell>
        <mxCell id="s3" value="3. Active Agent drops generation" style="rounded=1;whiteSpace=wrap;html=1;sketch=1;arcSize=40;strokeWidth=2;fillColor=#DAE8FC;strokeColor=#6C8EBF;align=center;verticalAlign=middle;fontSize=10;" vertex="1" parent="1"><mxGeometry x="540" y="780" width="180" height="60" as="geometry" /></mxCell>
        <mxCell id="s4" value="4. Pulls latest state snapshot" style="rounded=1;whiteSpace=wrap;html=1;sketch=1;arcSize=40;strokeWidth=2;fillColor=#E1D5E7;strokeColor=#9673A6;align=center;verticalAlign=middle;fontSize=10;" vertex="1" parent="1"><mxGeometry x="750" y="780" width="180" height="60" as="geometry" /></mxCell>
        <mxCell id="s5" value="5. Resumes on new intent — prior inputs intact" style="rounded=1;whiteSpace=wrap;html=1;sketch=1;arcSize=40;strokeWidth=2;fillColor=#D5E8D4;strokeColor=#82B366;align=center;verticalAlign=middle;fontSize=10;" vertex="1" parent="1"><mxGeometry x="960" y="780" width="200" height="60" as="geometry" /></mxCell>

        <mxCell id="note" value="Why split? The Active Agent stays fast (small context, streaming) so the caller never waits; the Passive Agent absorbs the heavy bookkeeping (DB writes, full state) off the critical path. Mid-call intent switches close one SubWorkflow and open another without dropping the call — the snapshot is the single source of truth handed back to the Active Agent." style="rounded=1;whiteSpace=wrap;html=1;sketch=1;arcSize=6;strokeWidth=1;dashed=1;dashPattern=6 4;fillColor=#F5F5F5;strokeColor=#999999;align=left;verticalAlign=top;spacingLeft=12;spacingTop=10;fontSize=11;fontColor=#444444;fontStyle=2;" vertex="1" parent="1"><mxGeometry x="120" y="880" width="1040" height="90" as="geometry" /></mxCell>

        <!-- edges -->
        <mxCell id="e0" value="call" style="edgeStyle=orthogonalEdgeStyle;rounded=1;sketch=1;html=1;endArrow=block;endFill=1;startArrow=block;startFill=1;strokeWidth=2;strokeColor=#555555;fontSize=10;" edge="1" parent="1" source="caller" target="twilio"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e1" value="audio in / out (WS)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;sketch=1;html=1;endArrow=block;endFill=1;startArrow=block;startFill=1;strokeWidth=2;strokeColor=#6C8EBF;fontSize=10;" edge="1" parent="1" source="twilio" target="active"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e2" value="WS tokens (listen)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;sketch=1;html=1;endArrow=block;endFill=1;strokeWidth=2;dashed=1;dashPattern=4 4;strokeColor=#9673A6;fontSize=10;" edge="1" parent="1" source="twilio" target="passive"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e3" value="request snapshot" style="edgeStyle=orthogonalEdgeStyle;rounded=1;sketch=1;html=1;endArrow=block;endFill=1;startArrow=block;startFill=1;strokeWidth=2;strokeColor=#9673A6;fontSize=10;fontColor=#333333;" edge="1" parent="1" source="active" target="passive"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e4" value="TTS" style="edgeStyle=orthogonalEdgeStyle;rounded=1;sketch=1;html=1;endArrow=block;endFill=1;startArrow=block;startFill=1;strokeWidth=1;strokeColor=#888888;fontSize=9;" edge="1" parent="1" source="active" target="el"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e5" value="ASR" style="edgeStyle=orthogonalEdgeStyle;rounded=1;sketch=1;html=1;endArrow=block;endFill=1;startArrow=block;startFill=1;strokeWidth=1;strokeColor=#888888;fontSize=9;" edge="1" parent="1" source="active" target="stt"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e6" value="reasoning" style="edgeStyle=orthogonalEdgeStyle;rounded=1;sketch=1;html=1;endArrow=block;endFill=1;startArrow=block;startFill=1;strokeWidth=1;strokeColor=#888888;fontSize=9;" edge="1" parent="1" source="passive" target="claude"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e7" value="persist / read" style="edgeStyle=orthogonalEdgeStyle;rounded=1;sketch=1;html=1;endArrow=block;endFill=1;startArrow=block;startFill=1;strokeWidth=2;strokeColor=#9673A6;fontSize=9;" edge="1" parent="1" source="passive" target="statedb"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="se1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;sketch=1;html=1;endArrow=block;endFill=1;strokeWidth=2;strokeColor=#B85450;" edge="1" parent="1" source="s1" target="s2"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="se2" style="edgeStyle=orthogonalEdgeStyle;rounded=1;sketch=1;html=1;endArrow=block;endFill=1;strokeWidth=2;strokeColor=#B85450;" edge="1" parent="1" source="s2" target="s3"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="se3" style="edgeStyle=orthogonalEdgeStyle;rounded=1;sketch=1;html=1;endArrow=block;endFill=1;strokeWidth=2;strokeColor=#B85450;" edge="1" parent="1" source="s3" target="s4"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="se4" style="edgeStyle=orthogonalEdgeStyle;rounded=1;sketch=1;html=1;endArrow=block;endFill=1;strokeWidth=2;strokeColor=#B85450;" edge="1" parent="1" source="s4" target="s5"><mxGeometry relative="1" as="geometry" /></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
