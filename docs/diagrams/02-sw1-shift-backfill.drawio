        <mxCell id="ed" value="yes" style="edgeStyle=orthogonalEdgeStyle;rounded=1;sketch=1;html=1;endArrow=block;endFill=1;strokeWidth=2;strokeColor=#82B366;fontSize=10;fontColor=#82B366;" edge="1" parent="1" source="d0" target="n2"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ee" style="edgeStyle=orthogonalEdgeStyle;rounded=1;sketch=1;html=1;endArrow=block;endFill=1;strokeWidth=2;strokeColor=#555555;" edge="1" parent="1" source="n2" target="n3"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ef" style="edgeStyle=orthogonalEdgeStyle;rounded=1;sketch=1;html=1;endArrow=block;endFill=1;strokeWidth=2;strokeColor=#555555;" edge="1" parent="1" source="n3" target="d1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="eg" value="yes" style="edgeStyle=orthogonalEdgeStyle;rounded=1;sketch=1;html=1;endArrow=block;endFill=1;strokeWidth=2;strokeColor=#82B366;fontSize=10;fontColor=#82B366;" edge="1" parent="1" source="d1" target="n4"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="eh" value="no" style="edgeStyle=orthogonalEdgeStyle;rounded=1;sketch=1;html=1;endArrow=block;endFill=1;strokeWidth=2;strokeColor=#B85450;fontSize=10;fontColor=#B85450;exitX=1;exitY=0.5;" edge="1" parent="1" source="d1" target="esc"><mxGeometry relative="1" as="geometry" /></mxCell>
