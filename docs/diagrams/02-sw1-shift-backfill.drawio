<mxfile host="app.diagrams.net" agent="claude" version="24.0.0">
  <diagram id="sw1" name="02 · SW1 Shift-Backfill Cascade">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="1300" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title" value="SUBWORKFLOW 1 — The 6:00 AM Shift-Backfill Cascade" style="text;html=1;align=center;verticalAlign=middle;fontSize=20;fontStyle=1;fontColor=#1A1A1A;" vertex="1" parent="1"><mxGeometry x="200" y="16" width="900" height="34" as="geometry" /></mxCell>
        <mxCell id="badge" value="1" style="ellipse;whiteSpace=wrap;html=1;sketch=1;fillColor=#FFFFFF;strokeColor=#6C8EBF;strokeWidth=3;fontSize=20;fontStyle=1;fontColor=#6C8EBF;" vertex="1" parent="1"><mxGeometry x="140" y="14" width="44" height="44" as="geometry" /></mxCell>

        <mxCell id="trig" value="&lt;b&gt;TRIGGER&lt;/b&gt;&#10;Caregiver calls out sick / emergency&#10;(Orchestrator routes to SW1)" style="rounded=1;whiteSpace=wrap;html=1;sketch=1;arcSize=40;strokeWidth=2;fillColor=#F8CECC;strokeColor=#B85450;align=center;verticalAlign=middle;fontSize=12;" vertex="1" parent="1"><mxGeometry x="440" y="80" width="300" height="70" as="geometry" /></mxCell>

        <mxCell id="n1" value="Confirm the shift being vacated&#10;(patient · time · location)" style="rounded=1;whiteSpace=wrap;html=1;sketch=1;arcSize=10;strokeWidth=2;fillColor=#DAE8FC;strokeColor=#6C8EBF;align=center;verticalAlign=middle;fontSize=11;" vertex="1" parent="1"><mxGeometry x="450" y="185" width="280" height="55" as="geometry" /></mxCell>
        <mxCell id="d0" value="Caller identity =&#10;assigned caregiver?" style="rhombus;whiteSpace=wrap;html=1;sketch=1;strokeWidth=2;fillColor=#FFF2CC;strokeColor=#D6B656;align=center;verticalAlign=middle;fontSize=10;" vertex="1" parent="1"><mxGeometry x="490" y="270" width="200" height="90" as="geometry" /></mxCell>
        <mxCell id="verify" value="Verify identity /&#10;flag for review" style="rounded=1;whiteSpace=wrap;html=1;sketch=1;arcSize=10;strokeWidth=2;fillColor=#F8CECC;strokeColor=#B85450;align=center;verticalAlign=middle;fontSize=10;" vertex="1" parent="1"><mxGeometry x="760" y="285" width="180" height="60" as="geometry" /></mxCell>

        <mxCell id="n2" value="Log vacancy → shift status = &lt;b&gt;OPEN&lt;/b&gt;&#10;(record reason)" style="rounded=1;whiteSpace=wrap;html=1;sketch=1;arcSize=10;strokeWidth=2;fillColor=#DAE8FC;strokeColor=#6C8EBF;align=center;verticalAlign=middle;fontSize=11;" vertex="1" parent="1"><mxGeometry x="450" y="390" width="280" height="55" as="geometry" /></mxCell>
        <mxCell id="n3" value="&lt;b&gt;Async query&lt;/b&gt; for compliant backups&#10;(certification · language · proximity)" style="rounded=1;whiteSpace=wrap;html=1;sketch=1;arcSize=10;strokeWidth=2;fillColor=#DAE8FC;strokeColor=#6C8EBF;align=center;verticalAlign=middle;fontSize=11;" vertex="1" parent="1"><mxGeometry x="450" y="470" width="280" height="55" as="geometry" /></mxCell>
        <mxCell id="d1" value="Backups&#10;available?" style="rhombus;whiteSpace=wrap;html=1;sketch=1;strokeWidth=2;fillColor=#FFF2CC;strokeColor=#D6B656;align=center;verticalAlign=middle;fontSize=11;" vertex="1" parent="1"><mxGeometry x="510" y="555" width="160" height="90" as="geometry" /></mxCell>

        <mxCell id="n4" value="Rank backups (best match first)" style="rounded=1;whiteSpace=wrap;html=1;sketch=1;arcSize=10;strokeWidth=2;fillColor=#DAE8FC;strokeColor=#6C8EBF;align=center;verticalAlign=middle;fontSize=11;" vertex="1" parent="1"><mxGeometry x="450" y="680" width="280" height="50" as="geometry" /></mxCell>
        <mxCell id="n5" value="&lt;b&gt;Fire cascade&lt;/b&gt; — targeted SMS + voice&#10;(Twilio · sequential w/ timeout or broadcast)" style="rounded=1;whiteSpace=wrap;html=1;sketch=1;arcSize=10;strokeWidth=2;fillColor=#DAE8FC;strokeColor=#6C8EBF;align=center;verticalAlign=middle;fontSize=11;" vertex="1" parent="1"><mxGeometry x="450" y="755" width="280" height="55" as="geometry" /></mxCell>
        <mxCell id="d2" value="&quot;YES&quot;&#10;received?" style="rhombus;whiteSpace=wrap;html=1;sketch=1;strokeWidth=2;fillColor=#FFF2CC;strokeColor=#D6B656;align=center;verticalAlign=middle;fontSize=11;" vertex="1" parent="1"><mxGeometry x="510" y="840" width="160" height="90" as="geometry" /></mxCell>
        <mxCell id="d3" value="List&#10;exhausted?" style="rhombus;whiteSpace=wrap;html=1;sketch=1;strokeWidth=2;fillColor=#FFF2CC;strokeColor=#D6B656;align=center;verticalAlign=middle;fontSize=10;" vertex="1" parent="1"><mxGeometry x="760" y="840" width="150" height="90" as="geometry" /></mxCell>

        <mxCell id="lock" value="&lt;b&gt;Lock shift&lt;/b&gt; — first-YES-wins (race-safe)&#10;Notify others: &quot;already filled&quot;" style="rounded=1;whiteSpace=wrap;html=1;sketch=1;arcSize=10;strokeWidth=2;fillColor=#D5E8D4;strokeColor=#82B366;align=center;verticalAlign=middle;fontSize=11;" vertex="1" parent="1"><mxGeometry x="440" y="970" width="300" height="55" as="geometry" /></mxCell>
        <mxCell id="upd" value="Update calendar → &lt;b&gt;FILLED&lt;/b&gt; · write audit&#10;Return control to Orchestrator + summary" style="rounded=1;whiteSpace=wrap;html=1;sketch=1;arcSize=10;strokeWidth=2;fillColor=#D5E8D4;strokeColor=#82B366;align=center;verticalAlign=middle;fontSize=11;" vertex="1" parent="1"><mxGeometry x="440" y="1055" width="300" height="55" as="geometry" /></mxCell>

        <mxCell id="esc" value="&lt;b&gt;Escalate to human scheduler&lt;/b&gt;&#10;with summary of who was contacted" style="rounded=1;whiteSpace=wrap;html=1;sketch=1;arcSize=10;strokeWidth=2;fillColor=#F8CECC;strokeColor=#B85450;align=center;verticalAlign=middle;fontSize=11;" vertex="1" parent="1"><mxGeometry x="950" y="960" width="240" height="70" as="geometry" /></mxCell>

        <!-- side panels -->
        <mxCell id="data" value="&lt;b&gt;DATA TOUCHED&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;b&gt;Read:&lt;/b&gt; caregiver profile, today&#39;s shift, backup roster (Neo4j), compliance status&lt;br&gt;&lt;br&gt;&lt;b&gt;Write:&lt;/b&gt; shift status (OPEN→FILLED), new assignment, cascade attempt log, audit entry" style="rounded=1;whiteSpace=wrap;html=1;sketch=1;arcSize=6;strokeWidth=2;fillColor=#E1D5E7;strokeColor=#9673A6;align=left;verticalAlign=top;spacingLeft=12;spacingTop=10;fontSize=10;fontColor=#1A1A1A;" vertex="1" parent="1"><mxGeometry x="60" y="390" width="330" height="150" as="geometry" /></mxCell>
        <mxCell id="integ" value="&lt;b&gt;INTEGRATIONS&lt;/b&gt;&lt;br&gt;&lt;br&gt;• Twilio Voice + SMS — cascade&lt;br&gt;• Neo4j — compliant-backup Cypher&lt;br&gt;• ElevenLabs — outbound voice&lt;br&gt;• Shift Calendars API — status" style="rounded=1;whiteSpace=wrap;html=1;sketch=1;arcSize=6;strokeWidth=2;fillColor=#DAE8FC;strokeColor=#6C8EBF;align=left;verticalAlign=top;spacingLeft=12;spacingTop=10;fontSize=10;fontColor=#1A1A1A;" vertex="1" parent="1"><mxGeometry x="60" y="565" width="330" height="120" as="geometry" /></mxCell>
        <mxCell id="edge" value="&lt;b&gt;EDGE CASES&lt;/b&gt;&lt;br&gt;&lt;br&gt;• Multiple &quot;YES&quot; race → first accepted wins&lt;br&gt;• Backup accepts then unreachable → re-open, resume&lt;br&gt;• Caller not the assigned caregiver → verify first&lt;br&gt;• No one accepts → escalate with contact history&lt;br&gt;&lt;br&gt;&lt;b&gt;VALUE:&lt;/b&gt; 45 min → ~5 min · protects $150–$300 / cancellation" style="rounded=1;whiteSpace=wrap;html=1;sketch=1;arcSize=6;strokeWidth=2;dashed=1;dashPattern=6 4;fillColor=#F5F5F5;strokeColor=#999999;align=left;verticalAlign=top;spacingLeft=12;spacingTop=10;fontSize=10;fontColor=#444444;" vertex="1" parent="1"><mxGeometry x="60" y="720" width="330" height="200" as="geometry" /></mxCell>

