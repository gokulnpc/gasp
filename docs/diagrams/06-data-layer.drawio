<mxfile host="app.diagrams.net" agent="claude" version="24.0.0">
  <diagram id="data-layer" name="06 · Data Layer &amp; Graph Model">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title" value="BACKEND DATA LAYER — Neo4j Property Graph &amp; Stores" style="text;html=1;align=center;verticalAlign=middle;fontSize=20;fontStyle=1;fontColor=#1A1A1A;" vertex="1" parent="1"><mxGeometry x="250" y="16" width="900" height="34" as="geometry" /></mxCell>

        <!-- Graph container -->
        <mxCell id="graphBox" value="&lt;b&gt;Neo4j Graph-Relational Roster&lt;/b&gt;  —  &quot;find a compliant, nearby, language-matched caregiver&quot; is a traversal, not a join" style="rounded=1;whiteSpace=wrap;html=1;sketch=1;arcSize=2;strokeWidth=2;dashed=1;dashPattern=8 4;fillColor=none;strokeColor=#9673A6;align=center;verticalAlign=top;spacingTop=8;fontSize=12;fontColor=#6A4A8A;" vertex="1" parent="1"><mxGeometry x="40" y="80" width="820" height="760" as="geometry" /></mxCell>

        <!-- nodes -->
        <mxCell id="cg" value="Caregiver&#10;id · name · phone&#10;status · availability" style="ellipse;whiteSpace=wrap;html=1;sketch=1;strokeWidth=2;fillColor=#DAE8FC;strokeColor=#6C8EBF;align=center;verticalAlign=middle;fontSize=11;" vertex="1" parent="1"><mxGeometry x="280" y="140" width="150" height="90" as="geometry" /></mxCell>
        <mxCell id="pt" value="Patient&#10;id · name · phone&#10;care_needs · address" style="ellipse;whiteSpace=wrap;html=1;sketch=1;strokeWidth=2;fillColor=#D5E8D4;strokeColor=#82B366;align=center;verticalAlign=middle;fontSize=11;" vertex="1" parent="1"><mxGeometry x="280" y="600" width="150" height="90" as="geometry" /></mxCell>
        <mxCell id="cert" value="Certification&#10;id · name&#10;(CNA/HHA/RN)" style="ellipse;whiteSpace=wrap;html=1;sketch=1;strokeWidth=2;fillColor=#FFF2CC;strokeColor=#D6B656;align=center;verticalAlign=middle;fontSize=11;" vertex="1" parent="1"><mxGeometry x="600" y="120" width="140" height="80" as="geometry" /></mxCell>
        <mxCell id="lang" value="Language&#10;code · name" style="ellipse;whiteSpace=wrap;html=1;sketch=1;strokeWidth=2;fillColor=#E1D5E7;strokeColor=#9673A6;align=center;verticalAlign=middle;fontSize=11;" vertex="1" parent="1"><mxGeometry x="600" y="290" width="140" height="80" as="geometry" /></mxCell>
        <mxCell id="locA" value="Location&#10;id · zip · geo" style="ellipse;whiteSpace=wrap;html=1;sketch=1;strokeWidth=2;fillColor=#FFE6CC;strokeColor=#D79B00;align=center;verticalAlign=middle;fontSize=11;" vertex="1" parent="1"><mxGeometry x="560" y="450" width="130" height="80" as="geometry" /></mxCell>
        <mxCell id="locB" value="Location&#10;id · zip · geo" style="ellipse;whiteSpace=wrap;html=1;sketch=1;strokeWidth=2;fillColor=#FFE6CC;strokeColor=#D79B00;align=center;verticalAlign=middle;fontSize=11;" vertex="1" parent="1"><mxGeometry x="590" y="640" width="130" height="80" as="geometry" /></mxCell>
        <mxCell id="shift" value="Shift&#10;id · start · end&#10;status" style="ellipse;whiteSpace=wrap;html=1;sketch=1;strokeWidth=2;fillColor=#F8CECC;strokeColor=#B85450;align=center;verticalAlign=middle;fontSize=11;" vertex="1" parent="1"><mxGeometry x="80" y="370" width="140" height="90" as="geometry" /></mxCell>

        <!-- relationships -->
        <mxCell id="r1" value="HOLDS" style="edgeStyle=none;rounded=0;sketch=1;html=1;endArrow=block;endFill=1;strokeWidth=2;strokeColor=#6C8EBF;fontSize=10;fontColor=#333333;" edge="1" parent="1" source="cg" target="cert"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="r2" value="SPEAKS" style="edgeStyle=none;rounded=0;sketch=1;html=1;endArrow=block;endFill=1;strokeWidth=2;strokeColor=#6C8EBF;fontSize=10;fontColor=#333333;" edge="1" parent="1" source="cg" target="lang"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="r3" value="BASED_AT" style="edgeStyle=none;rounded=0;sketch=1;html=1;endArrow=block;endFill=1;strokeWidth=2;strokeColor=#6C8EBF;fontSize=10;fontColor=#333333;" edge="1" parent="1" source="cg" target="locA"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="r4" value="ASSIGNED_TO" style="edgeStyle=none;rounded=0;sketch=1;html=1;endArrow=block;endFill=1;strokeWidth=2;strokeColor=#6C8EBF;fontSize=10;fontColor=#333333;" edge="1" parent="1" source="cg" target="shift"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="r5" value="REQUIRES" style="edgeStyle=none;rounded=0;sketch=1;html=1;endArrow=block;endFill=1;strokeWidth=2;strokeColor=#82B366;fontSize=10;fontColor=#333333;" edge="1" parent="1" source="pt" target="cert"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="r6" value="PREFERS" style="edgeStyle=none;rounded=0;sketch=1;html=1;endArrow=block;endFill=1;strokeWidth=2;strokeColor=#82B366;fontSize=10;fontColor=#333333;" edge="1" parent="1" source="pt" target="lang"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="r7" value="LOCATED_AT" style="edgeStyle=none;rounded=0;sketch=1;html=1;endArrow=block;endFill=1;strokeWidth=2;strokeColor=#82B366;fontSize=10;fontColor=#333333;" edge="1" parent="1" source="pt" target="locA"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="r8" value="HAS_SHIFT" style="edgeStyle=none;rounded=0;sketch=1;html=1;endArrow=block;endFill=1;strokeWidth=2;strokeColor=#82B366;fontSize=10;fontColor=#333333;" edge="1" parent="1" source="pt" target="shift"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="r9" value="NEAR {minutes}" style="edgeStyle=none;rounded=0;sketch=1;html=1;endArrow=block;endFill=1;startArrow=block;startFill=1;strokeWidth=2;strokeColor=#D79B00;fontSize=10;fontColor=#B8860B;" edge="1" parent="1" source="locA" target="locB"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- Stores -->
        <mxCell id="cal" value="&lt;b&gt;Shift Calendars&lt;/b&gt;&lt;br&gt;&lt;br&gt;• shift_id (PK)&lt;br&gt;• patient_id · caregiver_id (nullable)&lt;br&gt;• start · end&lt;br&gt;• status: SCHEDULED · OPEN · FILLED · CANCELLED&lt;br&gt;• location&lt;br&gt;&lt;br&gt;&lt;i&gt;SCHEDULED → OPEN (call-out) → FILLED (accept)&lt;/i&gt;" style="shape=cylinder3;whiteSpace=wrap;html=1;sketch=1;boundedLbl=1;backgroundOutline=1;size=14;strokeWidth=2;fillColor=#DAE8FC;strokeColor=#6C8EBF;align=left;verticalAlign=top;spacingLeft=14;spacingTop=24;fontSize=10;fontColor=#1A1A1A;" vertex="1" parent="1"><mxGeometry x="900" y="90" width="440" height="210" as="geometry" /></mxCell>
        <mxCell id="check" value="&lt;b&gt;Task Checklists&lt;/b&gt; (per-patient daily med layout)&lt;br&gt;&lt;br&gt;• patient_id&lt;br&gt;• medication · dose (e.g. 500mg)&lt;br&gt;• schedule (time / frequency)&lt;br&gt;• route (e.g. oral)&lt;br&gt;• active (currently prescribed?)&lt;br&gt;&lt;br&gt;&lt;i&gt;Walked by the SW3 med-log questionnaire&lt;/i&gt;" style="shape=cylinder3;whiteSpace=wrap;html=1;sketch=1;boundedLbl=1;backgroundOutline=1;size=14;strokeWidth=2;fillColor=#FFF2CC;strokeColor=#D6B656;align=left;verticalAlign=top;spacingLeft=14;spacingTop=24;fontSize=10;fontColor=#1A1A1A;" vertex="1" parent="1"><mxGeometry x="900" y="330" width="440" height="210" as="geometry" /></mxCell>
        <mxCell id="audit" value="&lt;b&gt;Operational Audit Logs&lt;/b&gt; (append-only, compliance-grade)&lt;br&gt;&lt;br&gt;• Med-log entries (structured JSON)&lt;br&gt;• Escalation events + transcript summaries&lt;br&gt;• Cascade attempt history (who / when / outcome)&lt;br&gt;• Corrections = new appended entries w/ provenance&lt;br&gt;&lt;br&gt;&lt;i&gt;Never in-place edits — full audit trail&lt;/i&gt;" style="shape=cylinder3;whiteSpace=wrap;html=1;sketch=1;boundedLbl=1;backgroundOutline=1;size=14;strokeWidth=2;fillColor=#D5E8D4;strokeColor=#82B366;align=left;verticalAlign=top;spacingLeft=14;spacingTop=24;fontSize=10;fontColor=#1A1A1A;" vertex="1" parent="1"><mxGeometry x="900" y="570" width="440" height="200" as="geometry" /></mxCell>

        <mxCell id="derived" value="&lt;b&gt;Post-Call Summary (derived)&lt;/b&gt; — not a store of its own; the Passive Agent generates a structured summary at call end from the entities above and pushes it to the staff portal." style="rounded=1;whiteSpace=wrap;html=1;sketch=1;arcSize=6;strokeWidth=1;dashed=1;dashPattern=6 4;fillColor=#F5F5F5;strokeColor=#999999;align=left;verticalAlign=middle;spacingLeft=12;fontSize=10;fontColor=#444444;fontStyle=2;" vertex="1" parent="1"><mxGeometry x="900" y="790" width="440" height="60" as="geometry" /></mxCell>

        <!-- legend -->
        <mxCell id="oq" value="&lt;b&gt;OPEN QUESTIONS&lt;/b&gt;&lt;br&gt;• Neo4j only, or Neo4j (graph) + relational/doc store for calendars &amp;amp; logs?&lt;br&gt;• Where do live conversation-state snapshots live — fast cache vs graph?&lt;br&gt;• Exact audit-approved JSON schema for med-log entries&lt;br&gt;• PHI segregation &amp;amp; access control" style="rounded=1;whiteSpace=wrap;html=1;sketch=1;arcSize=4;strokeWidth=1;dashed=1;dashPattern=6 4;fillColor=#FFF8E1;strokeColor=#D6B656;align=left;verticalAlign=top;spacingLeft=12;spacingTop=8;fontSize=10;fontColor=#5A4A00;" vertex="1" parent="1"><mxGeometry x="60" y="770" width="780" height="60" as="geometry" /></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
