<mxfile host="app.diagrams.net" agent="claude" version="24.0.0">
  <diagram id="sys-arch" name="00 · System Architecture">
    <mxGraphModel dx="1600" dy="1000" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2000" pageHeight="1320" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title" value="THE HEALTHCARE OMNI-AGENT — SYSTEM ARCHITECTURE" style="text;html=1;align=center;verticalAlign=middle;fontSize=24;fontStyle=1;fontColor=#1A1A1A;" vertex="1" parent="1"><mxGeometry x="360" y="16" width="1000" height="40" as="geometry" /></mxCell>
        <mxCell id="subtitle" value="Main Orchestrator + SubWorkflows · Dual-Agent Core (Active + Passive) · Twilio / ElevenLabs / Neo4j / Claude Opus 4.8" style="text;html=1;align=center;verticalAlign=middle;fontSize=13;fontColor=#555555;" vertex="1" parent="1"><mxGeometry x="360" y="56" width="1000" height="22" as="geometry" /></mxCell>

        <mxCell id="legend" value="&lt;b&gt;LEGEND&lt;/b&gt;&lt;br&gt;&lt;br&gt;━▶  solid = control / data flow&lt;br&gt;&lt;font color=&quot;#B85450&quot;&gt;╌▶  red dashed = escalation / override&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#888888&quot;&gt;╌▶  grey dashed = future / config&lt;/font&gt;&lt;br&gt;&lt;br&gt;&lt;font color=&quot;#82B366&quot;&gt;●&lt;/font&gt; Ready / Shift Filled&amp;nbsp;&amp;nbsp;&lt;font color=&quot;#D6B656&quot;&gt;●&lt;/font&gt; Awaiting Reply&lt;br&gt;&lt;font color=&quot;#B85450&quot;&gt;●&lt;/font&gt; Needs Human Review" style="rounded=1;whiteSpace=wrap;html=1;sketch=1;arcSize=6;strokeWidth=1;dashed=1;dashPattern=6 4;fillColor=#F5F5F5;strokeColor=#999999;align=left;verticalAlign=top;spacingLeft=12;spacingTop=8;fontSize=11;fontColor=#333333;" vertex="1" parent="1"><mxGeometry x="1560" y="20" width="360" height="150" as="geometry" /></mxCell>

        <!-- Caller -->
        <mxCell id="caller" value="Caller&#10;(Patient / Caregiver /&#10;Referring Family)" style="shape=umlActor;verticalLabelPosition=bottom;verticalAlign=top;html=1;outlineConnect=0;sketch=1;strokeColor=#333333;fillColor=#DAE8FC;fontSize=11;" vertex="1" parent="1"><mxGeometry x="60" y="360" width="60" height="100" as="geometry" /></mxCell>

        <!-- Twilio Gateway -->
        <mxCell id="twilio" value="&lt;b&gt;TWILIO GATEWAY&lt;/b&gt;&lt;br&gt;&lt;br&gt;• Programmable Voice&lt;br&gt;• SMS (cascade)&lt;br&gt;• Video (field validation)&lt;br&gt;• Media Streams (WebSocket)&lt;br&gt;• Barge-in playback control&lt;br&gt;• Webhook signature verify" style="rounded=1;whiteSpace=wrap;html=1;sketch=1;arcSize=8;strokeWidth=2;fillColor=#DAE8FC;strokeColor=#6C8EBF;align=left;verticalAlign=top;spacingLeft=12;spacingTop=10;fontSize=11;fontColor=#1A1A1A;" vertex="1" parent="1"><mxGeometry x="160" y="300" width="140" height="210" as="geometry" /></mxCell>

        <!-- Orchestrator -->
        <mxCell id="orch" value="&lt;b style=&quot;font-size:15px&quot;&gt;MAIN ORCHESTRATOR AGENT&lt;/b&gt;&lt;br&gt;&lt;i&gt;Intent &amp;amp; State Router&lt;/i&gt;&lt;br&gt;&lt;br&gt;• Answers every Twilio call&lt;br&gt;• Caller-ID recognition → greet by name&lt;br&gt;• Native language detection&lt;br&gt;• Intent detection &amp;amp; routing&lt;br&gt;• Global conversation state (hub)&lt;br&gt;• Mid-call intent switching (no dropped call)&lt;br&gt;• Returns control after each SubWorkflow" style="rounded=1;whiteSpace=wrap;html=1;sketch=1;arcSize=8;strokeWidth=2;fillColor=#FFE6CC;strokeColor=#D79B00;align=left;verticalAlign=top;spacingLeft=14;spacingTop=12;fontSize=12;fontColor=#1A1A1A;" vertex="1" parent="1"><mxGeometry x="340" y="290" width="340" height="240" as="geometry" /></mxCell>
        <mxCell id="orchBadge" value="OA" style="ellipse;whiteSpace=wrap;html=1;sketch=1;fillColor=#FFFFFF;strokeColor=#D79B00;strokeWidth=2;fontSize=13;fontStyle=1;fontColor=#D79B00;" vertex="1" parent="1"><mxGeometry x="322" y="276" width="40" height="40" as="geometry" /></mxCell>

        <!-- Dual-Agent Core container -->
        <mxCell id="core" value="&lt;b&gt;DUAL-AGENT CORE&lt;/b&gt; — Barge-In Failsafe" style="rounded=1;whiteSpace=wrap;html=1;sketch=1;arcSize=4;strokeWidth=2;dashed=1;dashPattern=8 4;fillColor=none;strokeColor=#666666;align=center;verticalAlign=top;spacingTop=8;fontSize=12;fontColor=#333333;" vertex="1" parent="1"><mxGeometry x="320" y="560" width="360" height="290" as="geometry" /></mxCell>
        <mxCell id="active" value="&lt;b&gt;ACTIVE AGENT&lt;/b&gt;&lt;br&gt;&lt;i&gt;Voice I/O&lt;/i&gt;&lt;br&gt;&lt;br&gt;• Real-time audio stream&lt;br&gt;• ElevenLabs streaming TTS&lt;br&gt;• Streaming STT (ASR)&lt;br&gt;• Lightweight context&lt;br&gt;• Drops generation on barge-in&lt;br&gt;• Pulls state snapshot" style="rounded=1;whiteSpace=wrap;html=1;sketch=1;arcSize=8;strokeWidth=2;fillColor=#DAE8FC;strokeColor=#6C8EBF;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;fontSize=11;fontColor=#1A1A1A;" vertex="1" parent="1"><mxGeometry x="335" y="598" width="160" height="185" as="geometry" /></mxCell>
        <mxCell id="passive" value="&lt;b&gt;PASSIVE AGENT&lt;/b&gt;&lt;br&gt;&lt;i&gt;Context Ledger&lt;/i&gt;&lt;br&gt;&lt;br&gt;• Listens to WS tokens&lt;br&gt;• Updates central DB&lt;br&gt;• Holds global state&lt;br&gt;• Emits state snapshots&lt;br&gt;• Post-call summary" style="rounded=1;whiteSpace=wrap;html=1;sketch=1;arcSize=8;strokeWidth=2;fillColor=#E1D5E7;strokeColor=#9673A6;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;fontSize=11;fontColor=#1A1A1A;" vertex="1" parent="1"><mxGeometry x="505" y="598" width="160" height="185" as="geometry" /></mxCell>
        <mxCell id="bargeNote" value="Barge-in: Twilio halts playback → Active Agent drops generation → pulls latest snapshot from Passive Agent → resumes on new intent, state intact." style="text;html=1;align=left;verticalAlign=middle;fontSize=10;fontColor=#666666;fontStyle=2;spacingLeft=6;" vertex="1" parent="1"><mxGeometry x="335" y="792" width="330" height="46" as="geometry" /></mxCell>

        <!-- AI/Voice services -->
        <mxCell id="el" value="&lt;b&gt;ElevenLabs&lt;/b&gt;&lt;br&gt;&lt;br&gt;Streaming TTS&lt;br&gt;ultra-low latency&lt;br&gt;natural voice" style="rounded=1;whiteSpace=wrap;html=1;sketch=1;arcSize=10;strokeWidth=2;fillColor=#FFF2CC;strokeColor=#D6B656;align=center;verticalAlign=middle;fontSize=10;fontColor=#1A1A1A;" vertex="1" parent="1"><mxGeometry x="330" y="880" width="105" height="95" as="geometry" /></mxCell>
        <mxCell id="stt" value="&lt;b&gt;Speech-to-Text&lt;/b&gt;&lt;br&gt;&lt;br&gt;Deepgram /&lt;br&gt;streaming ASR&lt;br&gt;(provider TBD)" style="rounded=1;whiteSpace=wrap;html=1;sketch=1;arcSize=10;strokeWidth=2;fillColor=#D5E8D4;strokeColor=#82B366;align=center;verticalAlign=middle;fontSize=10;fontColor=#1A1A1A;" vertex="1" parent="1"><mxGeometry x="447" y="880" width="105" height="95" as="geometry" /></mxCell>
        <mxCell id="claude" value="&lt;b&gt;Claude Opus 4.8&lt;/b&gt;&lt;br&gt;&lt;br&gt;Orchestrator +&lt;br&gt;agent reasoning&lt;br&gt;+ tool calling" style="rounded=1;whiteSpace=wrap;html=1;sketch=1;arcSize=10;strokeWidth=2;fillColor=#E1D5E7;strokeColor=#9673A6;align=center;verticalAlign=middle;fontSize=10;fontColor=#1A1A1A;" vertex="1" parent="1"><mxGeometry x="564" y="880" width="105" height="95" as="geometry" /></mxCell>

        <!-- SubWorkflows -->
        <mxCell id="sw1" value="&lt;b&gt;SUBWORKFLOW 1&lt;/b&gt;&lt;br&gt;&lt;b&gt;Shift-Backfill Cascade&lt;/b&gt;&lt;br&gt;&lt;br&gt;• Detect call-out → log vacancy&lt;br&gt;• Async query compliant backups (Neo4j)&lt;br&gt;• Outbound SMS + voice cascade (Twilio)&lt;br&gt;• First &quot;YES&quot; locks shift (race-safe)&lt;br&gt;• Update calendar → return to Orchestrator" style="rounded=1;whiteSpace=wrap;html=1;sketch=1;arcSize=8;strokeWidth=2;fillColor=#DAE8FC;strokeColor=#6C8EBF;align=left;verticalAlign=top;spacingLeft=14;spacingTop=10;fontSize=11;fontColor=#1A1A1A;" vertex="1" parent="1"><mxGeometry x="760" y="118" width="360" height="152" as="geometry" /></mxCell>
        <mxCell id="b1" value="1" style="ellipse;whiteSpace=wrap;html=1;sketch=1;fillColor=#FFFFFF;strokeColor=#6C8EBF;strokeWidth=2;fontSize=16;fontStyle=1;fontColor=#6C8EBF;" vertex="1" parent="1"><mxGeometry x="742" y="104" width="36" height="36" as="geometry" /></mxCell>

        <mxCell id="sw2" value="&lt;b&gt;SUBWORKFLOW 2&lt;/b&gt;&lt;br&gt;&lt;b&gt;Intelligent Intake &amp;amp; Graph Matching&lt;/b&gt;&lt;br&gt;&lt;br&gt;• Structured patient profile capture&lt;br&gt;• Neo4j Cypher match (language / certs / proximity)&lt;br&gt;• Rank candidate caregivers&lt;br&gt;• Propose optimal schedule&lt;br&gt;• Write schedule to calendar" style="rounded=1;whiteSpace=wrap;html=1;sketch=1;arcSize=8;strokeWidth=2;fillColor=#FFF2CC;strokeColor=#D6B656;align=left;verticalAlign=top;spacingLeft=14;spacingTop=10;fontSize=11;fontColor=#1A1A1A;" vertex="1" parent="1"><mxGeometry x="760" y="298" width="360" height="152" as="geometry" /></mxCell>
        <mxCell id="b2" value="2" style="ellipse;whiteSpace=wrap;html=1;sketch=1;fillColor=#FFFFFF;strokeColor=#D6B656;strokeWidth=2;fontSize=16;fontStyle=1;fontColor=#D6B656;" vertex="1" parent="1"><mxGeometry x="742" y="284" width="36" height="36" as="geometry" /></mxCell>

        <mxCell id="sw3" value="&lt;b&gt;SUBWORKFLOW 3&lt;/b&gt;&lt;br&gt;&lt;b&gt;Med-Log &amp;amp; Compliance Check-In&lt;/b&gt;&lt;br&gt;&lt;br&gt;• Strict per-med questionnaire&lt;br&gt;• Confirm doses vs active daily layout&lt;br&gt;• Voice → structured JSON&lt;br&gt;• Append to audit-ready logs&lt;br&gt;• Handle missed / refused / PRN" style="rounded=1;whiteSpace=wrap;html=1;sketch=1;arcSize=8;strokeWidth=2;fillColor=#D5E8D4;strokeColor=#82B366;align=left;verticalAlign=top;spacingLeft=14;spacingTop=10;fontSize=11;fontColor=#1A1A1A;" vertex="1" parent="1"><mxGeometry x="760" y="478" width="360" height="152" as="geometry" /></mxCell>
        <mxCell id="b3" value="3" style="ellipse;whiteSpace=wrap;html=1;sketch=1;fillColor=#FFFFFF;strokeColor=#82B366;strokeWidth=2;fontSize=16;fontStyle=1;fontColor=#82B366;" vertex="1" parent="1"><mxGeometry x="742" y="464" width="36" height="36" as="geometry" /></mxCell>

        <mxCell id="sw4" value="&lt;b&gt;SUBWORKFLOW 4&lt;/b&gt;&lt;br&gt;&lt;b&gt;Interpreter &amp;amp; Escalation Bridge&lt;/b&gt; &lt;i&gt;(Override)&lt;/i&gt;&lt;br&gt;&lt;br&gt;• Trigger: distress / severe pain / &quot;human&quot;&lt;br&gt;• Override active session (preserve state)&lt;br&gt;• Hot-dial triage coordinator&lt;br&gt;• Twilio conference patch&lt;br&gt;• Real-time two-way interpretation" style="rounded=1;whiteSpace=wrap;html=1;sketch=1;arcSize=8;strokeWidth=2;dashed=1;dashPattern=8 4;fillColor=#F8CECC;strokeColor=#B85450;align=left;verticalAlign=top;spacingLeft=14;spacingTop=10;fontSize=11;fontColor=#1A1A1A;" vertex="1" parent="1"><mxGeometry x="760" y="658" width="360" height="168" as="geometry" /></mxCell>
        <mxCell id="b4" value="4" style="ellipse;whiteSpace=wrap;html=1;sketch=1;fillColor=#FFFFFF;strokeColor=#B85450;strokeWidth=2;fontSize=16;fontStyle=1;fontColor=#B85450;" vertex="1" parent="1"><mxGeometry x="742" y="644" width="36" height="36" as="geometry" /></mxCell>

        <!-- Data Layer -->
        <mxCell id="dataLayer" value="&lt;b&gt;BACKEND DATA LAYER&lt;/b&gt; (Modular API Core)" style="rounded=1;whiteSpace=wrap;html=1;sketch=1;arcSize=3;strokeWidth=2;dashed=1;dashPattern=8 4;fillColor=none;strokeColor=#9673A6;align=center;verticalAlign=top;spacingTop=8;fontSize=12;fontColor=#6A4A8A;" vertex="1" parent="1"><mxGeometry x="1150" y="118" width="390" height="560" as="geometry" /></mxCell>
        <mxCell id="neo" value="&lt;b&gt;Neo4j Graph Roster&lt;/b&gt;&lt;br&gt;&lt;br&gt;• Caregivers / Patients&lt;br&gt;• Certifications&lt;br&gt;• Languages&lt;br&gt;• Location / proximity&lt;br&gt;• Cypher: match + backfill" style="shape=cylinder3;whiteSpace=wrap;html=1;sketch=1;boundedLbl=1;backgroundOutline=1;size=14;strokeWidth=2;fillColor=#E1D5E7;strokeColor=#9673A6;align=left;verticalAlign=top;spacingLeft=10;spacingTop=22;fontSize=10;fontColor=#1A1A1A;" vertex="1" parent="1"><mxGeometry x="1165" y="170" width="175" height="230" as="geometry" /></mxCell>
        <mxCell id="cal" value="&lt;b&gt;Shift Calendars&lt;/b&gt;&lt;br&gt;&lt;br&gt;• Visit slots&lt;br&gt;• Assignments&lt;br&gt;• Status: SCHEDULED →&lt;br&gt;&amp;nbsp;&amp;nbsp;OPEN → FILLED&lt;br&gt;• Race-safe locking" style="shape=cylinder3;whiteSpace=wrap;html=1;sketch=1;boundedLbl=1;backgroundOutline=1;size=14;strokeWidth=2;fillColor=#DAE8FC;strokeColor=#6C8EBF;align=left;verticalAlign=top;spacingLeft=10;spacingTop=22;fontSize=10;fontColor=#1A1A1A;" vertex="1" parent="1"><mxGeometry x="1350" y="170" width="175" height="230" as="geometry" /></mxCell>
        <mxCell id="audit" value="&lt;b&gt;Operational Audit Logs&lt;/b&gt;&lt;br&gt;&lt;br&gt;• Append-only&lt;br&gt;• Med-log JSON&lt;br&gt;• Escalation events&lt;br&gt;• Cascade history&lt;br&gt;• Corrections w/ provenance" style="shape=cylinder3;whiteSpace=wrap;html=1;sketch=1;boundedLbl=1;backgroundOutline=1;size=14;strokeWidth=2;fillColor=#D5E8D4;strokeColor=#82B366;align=left;verticalAlign=top;spacingLeft=10;spacingTop=22;fontSize=10;fontColor=#1A1A1A;" vertex="1" parent="1"><mxGeometry x="1165" y="420" width="175" height="245" as="geometry" /></mxCell>
        <mxCell id="check" value="&lt;b&gt;Task Checklists&lt;/b&gt;&lt;br&gt;&lt;br&gt;• Per-patient daily&lt;br&gt;&amp;nbsp;&amp;nbsp;med layout&lt;br&gt;• Drug / dose / time&lt;br&gt;• Active flag&lt;br&gt;• PRN handling" style="shape=cylinder3;whiteSpace=wrap;html=1;sketch=1;boundedLbl=1;backgroundOutline=1;size=14;strokeWidth=2;fillColor=#FFF2CC;strokeColor=#D6B656;align=left;verticalAlign=top;spacingLeft=10;spacingTop=22;fontSize=10;fontColor=#1A1A1A;" vertex="1" parent="1"><mxGeometry x="1350" y="420" width="175" height="245" as="geometry" /></mxCell>

        <!-- Portal / Outputs / actors -->
        <mxCell id="portal" value="&lt;b&gt;STAFF PORTAL / DASHBOARD&lt;/b&gt;&lt;br&gt;&lt;br&gt;• Structured post-call summaries&lt;br&gt;• Live call &amp;amp; shift status&lt;br&gt;• Compliance / audit view&lt;br&gt;• Patient ↔ caregiver matches&lt;br&gt;• Rules &amp;amp; config toggle" style="rounded=1;whiteSpace=wrap;html=1;sketch=1;arcSize=8;strokeWidth=2;fillColor=#D5E8D4;strokeColor=#82B366;align=left;verticalAlign=top;spacingLeft=12;spacingTop=10;fontSize=11;fontColor=#1A1A1A;" vertex="1" parent="1"><mxGeometry x="1580" y="200" width="330" height="180" as="geometry" /></mxCell>
        <mxCell id="outputs" value="&lt;b&gt;OUTPUTS&lt;/b&gt;&lt;br&gt;&lt;br&gt;• Portal push (real-time)&lt;br&gt;• Structured summary (JSON)&lt;br&gt;• Compliance export (CSV)&lt;br&gt;• Webhooks / API (future)" style="rounded=1;whiteSpace=wrap;html=1;sketch=1;arcSize=8;strokeWidth=2;fillColor=#D5E8D4;strokeColor=#82B366;align=left;verticalAlign=top;spacingLeft=12;spacingTop=10;fontSize=11;fontColor=#1A1A1A;" vertex="1" parent="1"><mxGeometry x="1580" y="410" width="330" height="150" as="geometry" /></mxCell>
        <mxCell id="biller" value="Agency Scheduler /&#10;Biller (End User)" style="shape=umlActor;verticalLabelPosition=bottom;verticalAlign=top;html=1;outlineConnect=0;sketch=1;strokeColor=#333333;fillColor=#D5E8D4;fontSize=11;" vertex="1" parent="1"><mxGeometry x="1715" y="600" width="60" height="90" as="geometry" /></mxCell>
        <mxCell id="triage" value="Human Triage&#10;Coordinator" style="shape=umlActor;verticalLabelPosition=bottom;verticalAlign=top;html=1;outlineConnect=0;sketch=1;strokeColor=#333333;fillColor=#F8CECC;fontSize=11;" vertex="1" parent="1"><mxGeometry x="1195" y="720" width="60" height="90" as="geometry" /></mxCell>

        <!-- NFR band -->
        <mxCell id="nfrBand" value="&lt;b&gt;NON-FUNCTIONAL REQUIREMENTS&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;sketch=1;arcSize=2;strokeWidth=2;dashed=1;dashPattern=8 4;fillColor=none;strokeColor=#666666;align=left;verticalAlign=top;spacingLeft=14;spacingTop=8;fontSize=12;fontColor=#333333;" vertex="1" parent="1"><mxGeometry x="60" y="1010" width="920" height="240" as="geometry" /></mxCell>
        <mxCell id="nfr1" value="&lt;b&gt;Latency&lt;/b&gt;&lt;br&gt;≤ ~1s TTFB · streaming STT/TTS · lightweight Active context" style="rounded=1;whiteSpace=wrap;html=1;sketch=1;arcSize=10;strokeWidth=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;fontSize=10;fontColor=#1A1A1A;" vertex="1" parent="1"><mxGeometry x="80" y="1050" width="280" height="80" as="geometry" /></mxCell>
        <mxCell id="nfr2" value="&lt;b&gt;HIPAA / PHI&lt;/b&gt;&lt;br&gt;Synthetic data in demo · append-only audit · consent prompts" style="rounded=1;whiteSpace=wrap;html=1;sketch=1;arcSize=10;strokeWidth=1;fillColor=#D5E8D4;strokeColor=#82B366;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;fontSize=10;fontColor=#1A1A1A;" vertex="1" parent="1"><mxGeometry x="375" y="1050" width="280" height="80" as="geometry" /></mxCell>
        <mxCell id="nfr3" value="&lt;b&gt;Reliability&lt;/b&gt;&lt;br&gt;Barge-in state · resume on dropped call · race-safe shift lock" style="rounded=1;whiteSpace=wrap;html=1;sketch=1;arcSize=10;strokeWidth=1;fillColor=#FFF2CC;strokeColor=#D6B656;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;fontSize=10;fontColor=#1A1A1A;" vertex="1" parent="1"><mxGeometry x="670" y="1050" width="290" height="80" as="geometry" /></mxCell>
        <mxCell id="nfr4" value="&lt;b&gt;Security&lt;/b&gt;&lt;br&gt;Webhook signature verify · secrets in env · least-privilege" style="rounded=1;whiteSpace=wrap;html=1;sketch=1;arcSize=10;strokeWidth=1;fillColor=#F8CECC;strokeColor=#B85450;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;fontSize=10;fontColor=#1A1A1A;" vertex="1" parent="1"><mxGeometry x="80" y="1145" width="280" height="80" as="geometry" /></mxCell>
        <mxCell id="nfr5" value="&lt;b&gt;i18n&lt;/b&gt;&lt;br&gt;Native language at answer time · interpreter bridge (SW4)" style="rounded=1;whiteSpace=wrap;html=1;sketch=1;arcSize=10;strokeWidth=1;fillColor=#E1D5E7;strokeColor=#9673A6;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;fontSize=10;fontColor=#1A1A1A;" vertex="1" parent="1"><mxGeometry x="375" y="1145" width="280" height="80" as="geometry" /></mxCell>
        <mxCell id="nfr6" value="&lt;b&gt;Observability&lt;/b&gt;&lt;br&gt;Per-turn latency metrics · summaries · cascade/escalation logs" style="rounded=1;whiteSpace=wrap;html=1;sketch=1;arcSize=10;strokeWidth=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;fontSize=10;fontColor=#1A1A1A;" vertex="1" parent="1"><mxGeometry x="670" y="1145" width="290" height="80" as="geometry" /></mxCell>

        <!-- Future scale band -->
        <mxCell id="futBand" value="&lt;b&gt;FUTURE PRODUCTION SCALE&lt;/b&gt; (Not for Hackathon)" style="rounded=1;whiteSpace=wrap;html=1;sketch=1;arcSize=2;strokeWidth=2;dashed=1;dashPattern=8 4;fillColor=none;strokeColor=#666666;align=left;verticalAlign=top;spacingLeft=14;spacingTop=8;fontSize=12;fontColor=#333333;" vertex="1" parent="1"><mxGeometry x="1020" y="1010" width="900" height="240" as="geometry" /></mxCell>
        <mxCell id="fut1" value="&lt;b&gt;Queue Workers&lt;/b&gt;&lt;br&gt;SQS / Kafka&lt;br&gt;(async cascade)" style="rounded=1;whiteSpace=wrap;html=1;sketch=1;arcSize=12;strokeWidth=1;fillColor=#E1D5E7;strokeColor=#9673A6;align=center;verticalAlign=middle;fontSize=10;fontColor=#1A1A1A;" vertex="1" parent="1"><mxGeometry x="1040" y="1060" width="185" height="80" as="geometry" /></mxCell>
        <mxCell id="fut2" value="&lt;b&gt;Object Storage&lt;/b&gt;&lt;br&gt;Raw audio /&lt;br&gt;transcript archive" style="rounded=1;whiteSpace=wrap;html=1;sketch=1;arcSize=12;strokeWidth=1;fillColor=#FFF2CC;strokeColor=#D6B656;align=center;verticalAlign=middle;fontSize=10;fontColor=#1A1A1A;" vertex="1" parent="1"><mxGeometry x="1265" y="1060" width="185" height="80" as="geometry" /></mxCell>
        <mxCell id="fut3" value="&lt;b&gt;Data Warehouse&lt;/b&gt;&lt;br&gt;Postgres / BigQuery /&lt;br&gt;Snowflake" style="rounded=1;whiteSpace=wrap;html=1;sketch=1;arcSize=12;strokeWidth=1;fillColor=#D5E8D4;strokeColor=#82B366;align=center;verticalAlign=middle;fontSize=10;fontColor=#1A1A1A;" vertex="1" parent="1"><mxGeometry x="1490" y="1060" width="185" height="80" as="geometry" /></mxCell>
